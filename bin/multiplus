#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_TEMPLATE_DIR="$REPO_ROOT/templates/workspace"
PROFILE_TEMPLATE_DIR="$REPO_ROOT/templates/profile"

usage() {
  cat <<'EOF'
Usage:
  multiplus init [--skip-fuelcheck] <target>
  multiplus profile add <name> [--workspace <dir>]
  multiplus profile list [--workspace <dir>]
  multiplus provider-root set <provider> <path> [--workspace <dir>]
  multiplus provider-root list [--workspace <dir>]
  multiplus use <name> [--workspace <dir>]
  multiplus login <name> [--workspace <dir>] [-- codex-login-args...]
  multiplus run [<name>] [--workspace <dir>] [-- codex-args...]
  multiplus preflight --account <name> [--workspace <dir>]
  multiplus codex --account <name> [--profile <codex-profile>] [--workspace <dir>] [-- codex-args...]
  multiplus mcp-server --account <name> [--profile <codex-profile>] [--workspace <dir>] [-- codex-mcp-args...]
  multiplus status [<name>] [--all] [--workspace <dir>] [--adapter <auto|codex|fuelcheck>]
  multiplus report status [<name>] [--all] [--workspace <dir>] [--adapter <auto|codex|fuelcheck>] [--output-dir <dir>]
  multiplus doctor [--workspace <dir>]

Environment:
  FUELCHECK_BIN                 Explicit fuelcheck binary path
  MULTIPLUS_CODEX_HOME          Override Codex auth root
  MULTIPLUS_CLAUDE_HOME         Override Claude auth root
  MULTIPLUS_GEMINI_HOME         Override Gemini auth root
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

format_duration() {
  local total="${1:-}"
  if [[ -z "$total" || ! "$total" =~ ^[0-9]+$ ]]; then
    return 0
  fi

  local days hours minutes seconds remainder
  days=$(( total / 86400 ))
  remainder=$(( total % 86400 ))
  hours=$(( remainder / 3600 ))
  remainder=$(( remainder % 3600 ))
  minutes=$(( remainder / 60 ))
  seconds=$(( remainder % 60 ))

  printf '%dd:%02dh:%02dm:%02ds' "$days" "$hours" "$minutes" "$seconds"
}

seconds_until_iso() {
  local iso="${1:-}"
  [[ -n "$iso" ]] || return 0
  local now epoch
  now="$(date -u +%s 2>/dev/null || true)"
  epoch="$(date -u -d "$iso" +%s 2>/dev/null || true)"
  if [[ -n "$now" && -n "$epoch" && "$epoch" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
    if (( epoch > now )); then
      printf '%s' "$(( epoch - now ))"
    else
      printf '0'
    fi
  fi
}

abspath() {
  local target="$1"
  if [[ -d "$target" ]]; then
    (cd "$target" && pwd)
  else
    local parent
    parent="$(cd "$(dirname "$target")" && pwd)"
    printf '%s/%s\n' "$parent" "$(basename "$target")"
  fi
}

workspace_state_dir() {
  local workspace="$1"
  printf '%s/.codex-home/state\n' "$workspace"
}

workspace_profiles_dir() {
  local workspace="$1"
  printf '%s/.codex-home/profiles\n' "$workspace"
}

workspace_default_file() {
  local workspace="$1"
  printf '%s/default-profile\n' "$(workspace_state_dir "$workspace")"
}

provider_roots_file() {
  local workspace="$1"
  printf '%s/provider-roots.env\n' "$(workspace_state_dir "$workspace")"
}

resolve_workspace() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    abspath "$explicit"
    return
  fi
  pwd
}

ensure_workspace_layout() {
  local workspace="$1"
  [[ -d "$workspace/.codex-home" ]] || fail "workspace is not initialized: $workspace"
}

profile_home() {
  local workspace="$1"
  local profile="$2"
  printf '%s/%s\n' "$(workspace_profiles_dir "$workspace")" "$profile"
}

profile_meta_file() {
  local workspace="$1"
  local profile="$2"
  printf '%s/.codex-home-profile\n' "$(profile_home "$workspace" "$profile")"
}

profile_exists() {
  local workspace="$1"
  local profile="$2"
  [[ -d "$(profile_home "$workspace" "$profile")" ]]
}

resolve_account_context() {
  local workspace="$1"
  local requested="${2:-}"
  local allow_default="${3:-false}"
  local account="$requested"

  if [[ -z "$account" && "$allow_default" == "true" ]]; then
    account="$(read_default_profile "$workspace")"
  fi

  [[ -n "$account" ]] || fail "no account specified and no default profile set"
  profile_exists "$workspace" "$account" || fail "unknown account: $account"

  printf '%s\t%s\n' "$account" "$(profile_home "$workspace" "$account")"
}

codex_profile_exists() {
  local account_home="$1"
  local codex_profile="$2"
  local config_file
  config_file="$account_home/.codex/config.toml"
  [[ -f "$config_file" ]] || return 1
  grep -Eq "^[[:space:]]*\\[profiles\\.${codex_profile//./\\.}\\][[:space:]]*$" "$config_file"
}

set_profile_env() {
  local workspace="$1"
  local profile="$2"
  local home_dir
  home_dir="$(profile_home "$workspace" "$profile")"
  export HOME="$home_dir"
  export XDG_CONFIG_HOME="$home_dir/.config"
  export XDG_CACHE_HOME="$home_dir/.cache"
  export XDG_DATA_HOME="$home_dir/.local/share"
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  cp -R "$src"/. "$dest"/
}

replace_placeholder() {
  local file="$1"
  local needle="$2"
  local value="$3"
  NEEDLE="$needle" VALUE="$value" perl -0pi -e 's/\Q$ENV{NEEDLE}\E/$ENV{VALUE}/g' "$file"
}

write_default_profile() {
  local workspace="$1"
  local profile="$2"
  mkdir -p "$(workspace_state_dir "$workspace")"
  printf '%s\n' "$profile" >"$(workspace_default_file "$workspace")"
}

read_default_profile() {
  local workspace="$1"
  local default_file
  default_file="$(workspace_default_file "$workspace")"
  if [[ -f "$default_file" ]]; then
    tr -d '\n' <"$default_file"
  fi
}

list_profiles() {
  local workspace="$1"
  local dir
  dir="$(workspace_profiles_dir "$workspace")"
  if [[ -d "$dir" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
  fi
}

normalize_provider_name() {
  local provider="${1:-}"
  case "$provider" in
    codex|claude|gemini) printf '%s\n' "$provider" ;;
    *) fail "unknown provider: $provider" ;;
  esac
}

provider_root_env_name() {
  local provider="$1"
  printf 'MULTIPLUS_%s_HOME\n' "$(printf '%s' "$provider" | tr '[:lower:]' '[:upper:]')"
}

read_provider_root_config() {
  local workspace="$1"
  local provider="$2"
  local file key
  file="$(provider_roots_file "$workspace")"
  key="$(provider_root_env_name "$provider")"
  if [[ -f "$file" ]]; then
    awk -F= -v key="$key" '$1==key {sub(/^[^=]*=/,""); print; exit}' "$file"
  fi
}

resolve_provider_root() {
  local workspace="$1"
  local provider="$2"
  local default_root="$3"
  local env_name config_value env_value
  env_name="$(provider_root_env_name "$provider")"
  env_value="${!env_name:-}"
  if [[ -n "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return
  fi
  config_value="$(read_provider_root_config "$workspace" "$provider")"
  if [[ -n "$config_value" ]]; then
    printf '%s\n' "$config_value"
    return
  fi
  printf '%s\n' "$default_root"
}

write_provider_root_config() {
  local workspace="$1"
  local provider="$2"
  local root="$3"
  local file key tmp
  mkdir -p "$(workspace_state_dir "$workspace")"
  file="$(provider_roots_file "$workspace")"
  key="$(provider_root_env_name "$provider")"
  tmp="$(mktemp)"
  if [[ -f "$file" ]]; then
    awk -F= -v key="$key" '$1!=key {print}' "$file" >"$tmp"
  fi
  printf '%s=%s\n' "$key" "$root" >>"$tmp"
  mv "$tmp" "$file"
}

cmd_provider_root_set() {
  local provider="${1:-}"
  local root="${2:-}"
  shift 2 || true
  provider="$(normalize_provider_name "$provider")"
  [[ -n "$root" ]] || fail "provider-root set requires a path"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for provider-root set: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  write_provider_root_config "$workspace" "$provider" "$(abspath "$root")"
  printf 'Provider root set: %s -> %s\n' "$provider" "$(read_provider_root_config "$workspace" "$provider")"
}

cmd_provider_root_list() {
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for provider-root list: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local provider root
  for provider in codex claude gemini; do
    root="$(resolve_provider_root "$workspace" "$provider" "")"
    if [[ -n "$root" ]]; then
      printf '%s %s\n' "$provider" "$root"
    else
      printf '%s (default)\n' "$provider"
    fi
  done
}

print_status_table_header() {
  printf '%-16s %-24s %-12s %-10s %-s\n' "PROFILE" "AUTH" "SOURCE" "DEFAULT" "HOME"
}

print_status_row() {
  local profile="$1"
  local auth="$2"
  local source="$3"
  local is_default="$4"
  local home_dir="$5"
  printf '%-16s %-24s %-12s %-10s %-s\n' "$profile" "$auth" "$source" "$is_default" "$home_dir"
}

find_fuelcheck_bin() {
  local workspace="${1:-}"
  if [[ -n "${FUELCHECK_BIN:-}" && -x "${FUELCHECK_BIN}" ]]; then
    printf '%s\n' "$FUELCHECK_BIN"
    return 0
  fi
  if [[ -n "$workspace" ]]; then
    local managed_bin
    managed_bin="$(managed_fuelcheck_bin "$workspace")"
    if [[ -x "$managed_bin" ]]; then
      printf '%s\n' "$managed_bin"
      return 0
    fi
  fi
  if command -v fuelcheck >/dev/null 2>&1; then
    command -v fuelcheck
    return 0
  fi
  return 1
}

managed_fuelcheck_root() {
  local workspace="$1"
  printf '%s/.codex-home/tools/fuelcheck\n' "$workspace"
}

managed_fuelcheck_bin() {
  local workspace="$1"
  printf '%s/bin/fuelcheck\n' "$(managed_fuelcheck_root "$workspace")"
}

install_managed_fuelcheck() {
  local workspace="$1"
  local managed_root managed_bin
  if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v cargo >/dev/null 2>&1; then
    fail "fuelcheck is required by default but cargo is missing; install cargo or rerun init with --skip-fuelcheck"
  fi
  managed_root="$(managed_fuelcheck_root "$workspace")"
  managed_bin="$(managed_fuelcheck_bin "$workspace")"
  mkdir -p "$managed_root"
  if ! cargo install --git https://github.com/emanuelarcos/fuelcheck --root "$managed_root"; then
    fail "failed to install fuelcheck; rerun init with --skip-fuelcheck to continue without it"
  fi
  [[ -x "$managed_bin" ]] || fail "fuelcheck install completed without a usable binary at $managed_bin"
  printf 'Installed managed fuelcheck at %s\n' "$managed_bin"
}

resolve_status_adapter() {
  local requested="$1"
  local workspace="${2:-}"
  case "$requested" in
    auto)
      if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
        printf 'fuelcheck\n'
      else
        printf 'codex\n'
      fi
      ;;
    codex|fuelcheck)
      printf '%s\n' "$requested"
      ;;
    *)
      fail "unknown adapter: $requested"
      ;;
  esac
}

collect_codex_login_status() {
  local auth="not logged in"
  if command -v codex >/dev/null 2>&1; then
    auth="$(codex login status 2>/dev/null || true)"
    [[ -n "$auth" ]] || auth="status unavailable"
  else
    auth="codex missing"
  fi
  printf '%s\n' "$auth"
}

collect_codex_login_status_for_account() {
  local workspace="$1"
  local account="$2"
  local context
  context="$(resolve_account_context "$workspace" "$account" "false")"
  local selected_account
  selected_account="${context%%$'\t'*}"
  set_profile_env "$workspace" "$selected_account"
  codex login status 2>/dev/null || true
}

auth_status_is_logged_in() {
  local auth_status="${1:-}"
  [[ -n "$auth_status" ]] || return 1
  [[ "$auth_status" == *"not logged in"* ]] && return 1
  [[ "$auth_status" == *"status unavailable"* ]] && return 1
  [[ "$auth_status" == *"codex missing"* ]] && return 1
  return 0
}

collect_fuelcheck_json() {
  local provider="$1"
  local home_root="$2"
  local workspace="${3:-}"
  local fuelcheck_bin
  fuelcheck_bin="$(find_fuelcheck_bin "$workspace")" || return 1
  HOME="$home_root" \
  XDG_CONFIG_HOME="$home_root/.config" \
  XDG_CACHE_HOME="$home_root/.cache" \
  XDG_DATA_HOME="$home_root/.local/share" \
  "$fuelcheck_bin" "$provider" --json 2>/dev/null
}

fuelcheck_field() {
  local json_file="$1"
  local jq_filter="$2"
  if command -v jq >/dev/null 2>&1 && [[ -f "$json_file" ]]; then
    jq -r "($jq_filter) | if . == null then empty else . end" "$json_file" 2>/dev/null || true
  fi
}

print_json_string_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": "%s",\n' "$key" "$(json_escape "$value")"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

print_json_number_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": %s,\n' "$key" "$value"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

print_json_bool_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": %s,\n' "$key" "$value"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

status_snapshot() {
  local workspace="$1"
  local profile="$2"
  local adapter="$3"
  set_profile_env "$workspace" "$profile"

  local auth source fuelcheck_json
  auth="$(collect_codex_login_status)"
  source="codex"

  if [[ "$adapter" == "fuelcheck" ]]; then
    if fuelcheck_json="$(collect_fuelcheck_json codex "$(resolve_provider_root "$workspace" codex "$(profile_home "$workspace" "$profile")")" "$workspace")"; then
      source="fuelcheck"
    else
      source="codex-fallback"
    fi
  fi

  printf '%s\t%s\n' "$auth" "$source"
}

cmd_init() {
  local target=""
  local skip_fuelcheck="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-fuelcheck)
        skip_fuelcheck="true"
        shift
        ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
          shift
        else
          fail "unknown option for init: $1"
        fi
        ;;
    esac
  done
  [[ -n "$target" ]] || fail "init requires a target path"
  local workspace
  workspace="$(abspath "$target")"
  mkdir -p "$workspace"

  copy_dir_contents "$WORKSPACE_TEMPLATE_DIR" "$workspace"
  mkdir -p "$workspace/.codex-home/profiles" "$workspace/.codex-home/state"

  replace_placeholder "$workspace/.codex/config.toml" "__WORKSPACE_ROOT__" "$workspace"
  replace_placeholder "$workspace/multiplus-local.sh" "__WORKSPACE_ROOT__" "$workspace"

  if [[ "$skip_fuelcheck" != "true" ]]; then
    install_managed_fuelcheck "$workspace"
  fi

  printf 'Initialized workspace at %s\n' "$workspace"
  printf 'Next steps:\n'
  printf '  %s profile add personal --workspace %s\n' "$0" "$workspace"
  printf '  %s login personal --workspace %s\n' "$0" "$workspace"
}

cmd_profile_add() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "profile add requires a profile name"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for profile add: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  local home_dir
  home_dir="$(profile_home "$workspace" "$profile")"
  if profile_exists "$workspace" "$profile"; then
    fail "profile already exists: $profile"
  fi

  copy_dir_contents "$PROFILE_TEMPLATE_DIR" "$home_dir"
  mkdir -p "$home_dir/.codex" "$home_dir/.config" "$home_dir/.cache" "$home_dir/.local/share"
  replace_placeholder "$home_dir/.codex/config.toml" "__WORKSPACE_ROOT__" "$workspace"
  replace_placeholder "$home_dir/.codex/config.toml" "__PROFILE_NAME__" "$profile"
  printf 'profile=%s\nworkspace=%s\n' "$profile" "$workspace" >"$(profile_meta_file "$workspace" "$profile")"

  if [[ -z "$(read_default_profile "$workspace")" ]]; then
    write_default_profile "$workspace" "$profile"
  fi

  printf 'Created profile %s at %s\n' "$profile" "$home_dir"
}

cmd_profile_list() {
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for profile list: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  while IFS= read -r profile; do
    [[ -n "$profile" ]] || continue
    if [[ "$profile" == "$default_profile" ]]; then
      printf '* %s\n' "$profile"
    else
      printf '  %s\n' "$profile"
    fi
  done < <(list_profiles "$workspace")
}

cmd_use() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "use requires an account name"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for use: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local context selected_account
  context="$(resolve_account_context "$workspace" "$profile" "false")"
  selected_account="${context%%$'\t'*}"
  write_default_profile "$workspace" "$selected_account"
  printf 'Default profile set to %s\n' "$selected_account"
}

cmd_login() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "login requires an account name"
  local workspace=""
  local extra_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --)
        shift
        extra_args=("$@")
        break
        ;;
      *)
        extra_args+=("$1")
        shift
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local context selected_account
  context="$(resolve_account_context "$workspace" "$profile" "false")"
  selected_account="${context%%$'\t'*}"
  require_cmd codex
  set_profile_env "$workspace" "$selected_account"
  exec codex login "${extra_args[@]}"
}

resolve_run_profile() {
  local workspace="$1"
  local candidate="${2:-}"
  local context selected_account
  if [[ -n "$candidate" && -d "$(profile_home "$workspace" "$candidate")" ]]; then
    context="$(resolve_account_context "$workspace" "$candidate" "false")"
  else
    context="$(resolve_account_context "$workspace" "" "true")"
  fi
  selected_account="${context%%$'\t'*}"
  printf '%s\n' "$selected_account"
}

cmd_run() {
  local maybe_profile=""
  local workspace=""
  local codex_args=()
  if [[ $# -gt 0 && "$1" != --* ]]; then
    maybe_profile="$1"
    shift
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --)
        shift
        codex_args=("$@")
        break
        ;;
      *)
        codex_args+=("$1")
        shift
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  require_cmd codex
  local profile
  profile="$(resolve_run_profile "$workspace" "$maybe_profile")"
  profile_exists "$workspace" "$profile" || fail "unknown profile: $profile"
  set_profile_env "$workspace" "$profile"
  exec codex -C "$workspace" "${codex_args[@]}"
}

cmd_preflight() {
  local workspace=""
  local account=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      *)
        fail "unknown option for preflight: $1"
        ;;
    esac
  done
  [[ -n "$account" ]] || fail "preflight requires --account <name>"
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  require_cmd codex

  local context selected_account selected_home auth_status
  context="$(resolve_account_context "$workspace" "$account" "false")"
  selected_account="${context%%$'\t'*}"
  selected_home="${context#*$'\t'}"
  [[ -d "$selected_home" ]] || fail "Codex home missing for account: $selected_account"

  auth_status="$(collect_codex_login_status_for_account "$workspace" "$selected_account")"
  auth_status="$(printf '%s' "$auth_status" | tr -d '\n')"
  if ! auth_status_is_logged_in "$auth_status"; then
    fail "no active login for selected account: $selected_account"
  fi

  printf 'Preflight ok\n'
  printf 'account: %s\n' "$selected_account"
  printf 'codex_home: %s\n' "$selected_home"
  printf 'auth_status: %s\n' "$auth_status"
}

cmd_codex() {
  local workspace=""
  local account=""
  local codex_profile=""
  local codex_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      --profile)
        codex_profile="$2"
        shift 2
        ;;
      --)
        shift
        codex_args=("$@")
        break
        ;;
      *)
        codex_args+=("$1")
        shift
        ;;
    esac
  done

  [[ -n "$account" ]] || fail "codex requires --account <name>"
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  require_cmd codex

  local context selected_account selected_home
  context="$(resolve_account_context "$workspace" "$account" "false")"
  selected_account="${context%%$'\t'*}"
  selected_home="${context#*$'\t'}"
  if [[ -n "$codex_profile" ]]; then
    codex_profile_exists "$selected_home" "$codex_profile" || fail "requested profile not defined in selected account: $codex_profile"
    if printf '%s\n' "${codex_args[@]}" | grep -qx -- '--profile'; then
      fail "profile specified twice; use either --profile on multiplus codex or pass it directly to codex"
    fi
    codex_args=(--profile "$codex_profile" "${codex_args[@]}")
  fi
  set_profile_env "$workspace" "$selected_account"
  exec codex -C "$workspace" "${codex_args[@]}"
}

cmd_mcp_server() {
  local workspace=""
  local account=""
  local codex_profile=""
  local mcp_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      --profile)
        codex_profile="$2"
        shift 2
        ;;
      --)
        shift
        mcp_args=("$@")
        break
        ;;
      *)
        mcp_args+=("$1")
        shift
        ;;
    esac
  done

  local codex_cmd=(--account "$account")
  if [[ -n "$codex_profile" ]]; then
    codex_cmd+=(--profile "$codex_profile")
  fi
  if [[ -n "$workspace" ]]; then
    codex_cmd+=(--workspace "$workspace")
  fi
  codex_cmd+=(-- mcp-server "${mcp_args[@]}")
  cmd_codex "${codex_cmd[@]}"
}

status_for_profile() {
  local workspace="$1"
  local profile="$2"
  local default_profile="$3"
  local adapter="$4"
  local snapshot auth source
  snapshot="$(status_snapshot "$workspace" "$profile" "$adapter")"
  auth="${snapshot%%$'\t'*}"
  source="${snapshot#*$'\t'}"
  local is_default="no"
  if [[ "$profile" == "$default_profile" ]]; then
    is_default="yes"
  fi
  print_status_row "$profile" "$auth" "$source" "$is_default" "$(profile_home "$workspace" "$profile")"
}

iterate_target_profiles() {
  local workspace="$1"
  local profile="$2"
  local all="$3"
  local default_profile
  default_profile="$(read_default_profile "$workspace")"

  if [[ "$all" == "true" ]]; then
    list_profiles "$workspace"
    return
  fi

  if [[ -z "$profile" ]]; then
    profile="$default_profile"
  fi
  [[ -n "$profile" ]] || fail "no profile specified and no default profile set"
  profile_exists "$workspace" "$profile" || fail "unknown profile: $profile"
  printf '%s\n' "$profile"
}

write_text_file() {
  local file="$1"
  local value="$2"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" >"$file"
}

cmd_report_status() {
  local profile=""
  local workspace=""
  local all="false"
  local requested_adapter="auto"
  local output_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --adapter)
        requested_adapter="$2"
        shift 2
        ;;
      --output-dir)
        output_dir="$2"
        shift 2
        ;;
      *)
        if [[ -z "$profile" ]]; then
          profile="$1"
          shift
        else
          fail "unknown option for report status: $1"
        fi
        ;;
    esac
  done

  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local adapter
  adapter="$(resolve_status_adapter "$requested_adapter" "$workspace")"
  if [[ -z "$output_dir" ]]; then
    output_dir="$workspace/.codex-home/artifacts/status"
  fi
  output_dir="$(abspath "$output_dir")"
  local raw_dir
  raw_dir="$output_dir/raw"
  mkdir -p "$raw_dir"

  local generated_at
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  local report_json
  report_json="$output_dir/status-report.json"
  local report_md
  report_md="$output_dir/status-report.md"

  {
    printf '{\n'
    printf '  "generated_at": "%s",\n' "$(json_escape "$generated_at")"
    printf '  "workspace": "%s",\n' "$(json_escape "$workspace")"
    printf '  "adapter_requested": "%s",\n' "$(json_escape "$requested_adapter")"
    printf '  "adapter_used": "%s",\n' "$(json_escape "$adapter")"
    printf '  "profiles": [\n'

    local first="true"
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      set_profile_env "$workspace" "$candidate"

      local auth source fuelcheck_status="not_run" fuelcheck_raw="" login_status_file
      local codex_file="" claude_file="" gemini_file=""
      local codex_root="" claude_root="" gemini_root=""
      local plan_type="" credits_balance="" credits_unlimited="" primary_used="" primary_reset="" weekly_used="" weekly_reset=""
      local primary_reset_human="" weekly_reset_human=""
      local claude_plan="" claude_source="" claude_five_used="" claude_five_reset_at="" claude_five_reset_seconds="" claude_five_reset_human=""
      local claude_week_used="" claude_week_reset_at="" claude_week_reset_seconds="" claude_week_reset_human=""
      local gemini_tier="" gemini_token_refreshed="" gemini_flash_used="" gemini_flash_reset_at="" gemini_flash_reset_seconds="" gemini_flash_reset_human=""
      local gemini_pro_used="" gemini_pro_reset_at="" gemini_pro_reset_seconds="" gemini_pro_reset_human=""
      local snapshot
      snapshot="$(status_snapshot "$workspace" "$candidate" "$adapter")"
      auth="${snapshot%%$'\t'*}"
      source="${snapshot#*$'\t'}"

      login_status_file="$raw_dir/${candidate}-login-status.txt"
      write_text_file "$login_status_file" "$auth"

      codex_root="$(resolve_provider_root "$workspace" codex "$(profile_home "$workspace" "$candidate")")"
      claude_root="$(resolve_provider_root "$workspace" claude "$(profile_home "$workspace" "$candidate")")"
      gemini_root="$(resolve_provider_root "$workspace" gemini "$(profile_home "$workspace" "$candidate")")"

      if [[ "$adapter" == "fuelcheck" ]]; then
        if fuelcheck_raw="$(collect_fuelcheck_json codex "$codex_root" "$workspace")"; then
          fuelcheck_status="ok"
          codex_file="$raw_dir/${candidate}-fuelcheck-codex.json"
          write_text_file "$codex_file" "$fuelcheck_raw"
          plan_type="$(fuelcheck_field "$codex_file" '.Codex.plan_type')"
          credits_balance="$(fuelcheck_field "$codex_file" '.Codex.credits.balance')"
          credits_unlimited="$(fuelcheck_field "$codex_file" '.Codex.credits.unlimited')"
          primary_used="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.primary_window.used_percent')"
          primary_reset="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.primary_window.reset_after_seconds')"
          weekly_used="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.secondary_window.used_percent')"
          weekly_reset="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.secondary_window.reset_after_seconds')"
          primary_reset_human="$(format_duration "$primary_reset")"
          weekly_reset_human="$(format_duration "$weekly_reset")"
        else
          fuelcheck_status="unavailable"
        fi
        if fuelcheck_raw="$(collect_fuelcheck_json claude "$claude_root" "$workspace")"; then
          claude_file="$raw_dir/${candidate}-fuelcheck-claude.json"
          write_text_file "$claude_file" "$fuelcheck_raw"
          claude_plan="$(fuelcheck_field "$claude_file" '.Claude.account.subscriptionType')"
          claude_source="$(fuelcheck_field "$claude_file" '.Claude.source')"
          claude_five_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.five_hour.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_five_reset_at="$(fuelcheck_field "$claude_file" '.Claude.usage.five_hour.resets_at')"
          claude_five_reset_seconds="$(seconds_until_iso "$claude_five_reset_at")"
          claude_five_reset_human="$(format_duration "$claude_five_reset_seconds")"
          claude_week_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.seven_day.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_week_reset_at="$(fuelcheck_field "$claude_file" '.Claude.usage.seven_day.resets_at')"
          claude_week_reset_seconds="$(seconds_until_iso "$claude_week_reset_at")"
          claude_week_reset_human="$(format_duration "$claude_week_reset_seconds")"
        fi
        if fuelcheck_raw="$(collect_fuelcheck_json gemini "$gemini_root" "$workspace")"; then
          gemini_file="$raw_dir/${candidate}-fuelcheck-gemini.json"
          write_text_file "$gemini_file" "$fuelcheck_raw"
          gemini_tier="$(fuelcheck_field "$gemini_file" '.Gemini.tier')"
          gemini_token_refreshed="$(fuelcheck_field "$gemini_file" '.Gemini.token_refreshed')"
          gemini_flash_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_flash_reset_at="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].resetTime)')"
          gemini_flash_reset_seconds="$(seconds_until_iso "$gemini_flash_reset_at")"
          gemini_flash_reset_human="$(format_duration "$gemini_flash_reset_seconds")"
          gemini_pro_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-pro" or .modelId=="gemini-3-pro-preview")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_pro_reset_at="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-pro" or .modelId=="gemini-3-pro-preview")][0].resetTime)')"
          gemini_pro_reset_seconds="$(seconds_until_iso "$gemini_pro_reset_at")"
          gemini_pro_reset_human="$(format_duration "$gemini_pro_reset_seconds")"
        fi
      fi

      if [[ "$first" != "true" ]]; then
        printf ',\n'
      fi
      first="false"

      printf '    {\n'
      printf '      "name": "%s",\n' "$(json_escape "$candidate")"
      printf '      "default": %s,\n' "$([[ "$candidate" == "$default_profile" ]] && printf 'true' || printf 'false')"
      printf '      "home": "%s",\n' "$(json_escape "$(profile_home "$workspace" "$candidate")")"
      printf '      "auth_status": "%s",\n' "$(json_escape "$auth")"
      printf '      "status_source": "%s",\n' "$(json_escape "$source")"
      printf '      "fuelcheck_status": "%s",\n' "$(json_escape "$fuelcheck_status")"
      if [[ -n "$plan_type" ]]; then
        printf '      "plan_type": "%s",\n' "$(json_escape "$plan_type")"
      else
        printf '      "plan_type": null,\n'
      fi
      if [[ -n "$credits_balance" ]]; then
        printf '      "credits_balance": "%s",\n' "$(json_escape "$credits_balance")"
      else
        printf '      "credits_balance": null,\n'
      fi
      if [[ -n "$credits_unlimited" ]]; then
        printf '      "credits_unlimited": %s,\n' "$credits_unlimited"
      else
        printf '      "credits_unlimited": null,\n'
      fi
      if [[ -n "$primary_used" ]]; then
        printf '      "five_hour_used_percent": %s,\n' "$primary_used"
      else
        printf '      "five_hour_used_percent": null,\n'
      fi
      if [[ -n "$primary_reset" ]]; then
        printf '      "five_hour_reset_after_seconds": %s,\n' "$primary_reset"
      else
        printf '      "five_hour_reset_after_seconds": null,\n'
      fi
      if [[ -n "$primary_reset_human" ]]; then
        printf '      "five_hour_reset_after_human": "%s",\n' "$(json_escape "$primary_reset_human")"
      else
        printf '      "five_hour_reset_after_human": null,\n'
      fi
      if [[ -n "$weekly_used" ]]; then
        printf '      "weekly_used_percent": %s,\n' "$weekly_used"
      else
        printf '      "weekly_used_percent": null,\n'
      fi
      if [[ -n "$weekly_reset" ]]; then
        printf '      "weekly_reset_after_seconds": %s,\n' "$weekly_reset"
      else
        printf '      "weekly_reset_after_seconds": null,\n'
      fi
      if [[ -n "$weekly_reset_human" ]]; then
        printf '      "weekly_reset_after_human": "%s",\n' "$(json_escape "$weekly_reset_human")"
      else
        printf '      "weekly_reset_after_human": null,\n'
      fi
      printf '      "providers": {\n'
      printf '        "codex": {\n'
      print_json_string_or_null "status" "$fuelcheck_status"
      print_json_string_or_null "plan_type" "$plan_type"
      print_json_string_or_null "credits_balance" "$credits_balance"
      print_json_bool_or_null "credits_unlimited" "$credits_unlimited"
      print_json_number_or_null "five_hour_used_percent" "$primary_used"
      print_json_number_or_null "five_hour_reset_after_seconds" "$primary_reset"
      print_json_string_or_null "five_hour_reset_after_human" "$primary_reset_human"
      print_json_number_or_null "weekly_used_percent" "$weekly_used"
      print_json_number_or_null "weekly_reset_after_seconds" "$weekly_reset"
      if [[ -n "$weekly_reset_human" ]]; then
        printf '        "weekly_reset_after_human": "%s"\n' "$(json_escape "$weekly_reset_human")"
      else
        printf '        "weekly_reset_after_human": null\n'
      fi
      printf '        },\n'
      printf '        "claude": {\n'
      if [[ -n "$claude_plan$claude_source$claude_five_used$claude_week_used" ]]; then
        print_json_string_or_null "status" "ok"
      else
        print_json_string_or_null "status" "unavailable"
      fi
      print_json_string_or_null "plan" "$claude_plan"
      print_json_string_or_null "source" "$claude_source"
      print_json_number_or_null "five_hour_used_percent" "$claude_five_used"
      print_json_string_or_null "five_hour_reset_at" "$claude_five_reset_at"
      print_json_number_or_null "five_hour_reset_after_seconds" "$claude_five_reset_seconds"
      print_json_string_or_null "five_hour_reset_after_human" "$claude_five_reset_human"
      print_json_number_or_null "weekly_used_percent" "$claude_week_used"
      print_json_string_or_null "weekly_reset_at" "$claude_week_reset_at"
      print_json_number_or_null "weekly_reset_after_seconds" "$claude_week_reset_seconds"
      if [[ -n "$claude_week_reset_human" ]]; then
        printf '        "weekly_reset_after_human": "%s"\n' "$(json_escape "$claude_week_reset_human")"
      else
        printf '        "weekly_reset_after_human": null\n'
      fi
      printf '        },\n'
      printf '        "gemini": {\n'
      if [[ -n "$gemini_tier$gemini_flash_used$gemini_pro_used$gemini_token_refreshed" ]]; then
        print_json_string_or_null "status" "ok"
      else
        print_json_string_or_null "status" "unavailable"
      fi
      print_json_string_or_null "tier" "$gemini_tier"
      print_json_bool_or_null "token_refreshed" "$gemini_token_refreshed"
      print_json_number_or_null "flash_used_percent" "$gemini_flash_used"
      print_json_string_or_null "flash_reset_at" "$gemini_flash_reset_at"
      print_json_number_or_null "flash_reset_after_seconds" "$gemini_flash_reset_seconds"
      print_json_string_or_null "flash_reset_after_human" "$gemini_flash_reset_human"
      print_json_number_or_null "pro_used_percent" "$gemini_pro_used"
      print_json_string_or_null "pro_reset_at" "$gemini_pro_reset_at"
      print_json_number_or_null "pro_reset_after_seconds" "$gemini_pro_reset_seconds"
      if [[ -n "$gemini_pro_reset_human" ]]; then
        printf '        "pro_reset_after_human": "%s"\n' "$(json_escape "$gemini_pro_reset_human")"
      else
        printf '        "pro_reset_after_human": null\n'
      fi
      printf '        }\n'
      printf '      },\n'
      printf '      "raw_files": {\n'
      printf '        "login_status": "%s",\n' "$(json_escape "$login_status_file")"
      if [[ -n "$codex_file" ]]; then printf '        "fuelcheck_codex_json": "%s",\n' "$(json_escape "$codex_file")"; else printf '        "fuelcheck_codex_json": null,\n'; fi
      if [[ -n "$claude_file" ]]; then printf '        "fuelcheck_claude_json": "%s",\n' "$(json_escape "$claude_file")"; else printf '        "fuelcheck_claude_json": null,\n'; fi
      if [[ -n "$gemini_file" ]]; then printf '        "fuelcheck_gemini_json": "%s"\n' "$(json_escape "$gemini_file")"; else printf '        "fuelcheck_gemini_json": null\n'; fi
      printf '      }\n'
      printf '    }'
    done < <(iterate_target_profiles "$workspace" "$profile" "$all")

    printf '\n  ]\n'
    printf '}\n'
  } >"$report_json"

  {
    printf '# Status Report\n\n'
    printf -- '- Generated at: `%s`\n' "$generated_at"
    printf -- '- Workspace: `%s`\n' "$workspace"
    printf -- '- Adapter requested: `%s`\n' "$requested_adapter"
    printf -- '- Adapter used: `%s`\n\n' "$adapter"
    printf '| Profile | Codex | Claude | Gemini | Default | Fuelcheck |\n'
    printf '|---|---|---|---|---|---|\n'
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      local snapshot auth source fuelcheck_status codex_file claude_file gemini_file plan_type primary_used primary_reset weekly_used weekly_reset primary_reset_human weekly_reset_human
      local claude_plan claude_five_used claude_five_reset_human gemini_tier gemini_flash_used gemini_flash_reset_human
      snapshot="$(status_snapshot "$workspace" "$candidate" "$adapter")"
      auth="${snapshot%%$'\t'*}"
      source="${snapshot#*$'\t'}"
      fuelcheck_status="n/a"
      plan_type="n/a"
      primary_used="n/a"
      primary_reset="n/a"
      weekly_used="n/a"
      weekly_reset="n/a"
      primary_reset_human="n/a"
      weekly_reset_human="n/a"
      claude_plan="n/a"
      claude_five_used="n/a"
      claude_five_reset_human="n/a"
      gemini_tier="n/a"
      gemini_flash_used="n/a"
      gemini_flash_reset_human="n/a"
      if [[ "$adapter" == "fuelcheck" ]]; then
        codex_file="$raw_dir/${candidate}-fuelcheck-codex.json"
        claude_file="$raw_dir/${candidate}-fuelcheck-claude.json"
        gemini_file="$raw_dir/${candidate}-fuelcheck-gemini.json"
        if [[ -f "$codex_file" ]]; then
          fuelcheck_status="ok"
          plan_type="$(fuelcheck_field "$codex_file" '.Codex.plan_type')"
          primary_used="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.primary_window.used_percent')"
          primary_reset="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.primary_window.reset_after_seconds')"
          weekly_used="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.secondary_window.used_percent')"
          weekly_reset="$(fuelcheck_field "$codex_file" '.Codex.rate_limit.secondary_window.reset_after_seconds')"
          primary_reset_human="$(format_duration "$primary_reset")"
          weekly_reset_human="$(format_duration "$weekly_reset")"
          [[ -n "$plan_type" ]] || plan_type="n/a"
          [[ -n "$primary_used" ]] || primary_used="n/a"
          [[ -n "$primary_reset_human" ]] || primary_reset_human="n/a"
        fi
        if [[ -f "$claude_file" ]]; then
          claude_plan="$(fuelcheck_field "$claude_file" '.Claude.account.subscriptionType')"
          claude_five_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.five_hour.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_five_reset_human="$(format_duration "$(seconds_until_iso "$(fuelcheck_field "$claude_file" '.Claude.usage.five_hour.resets_at')")")"
          [[ -n "$claude_plan" ]] || claude_plan="n/a"
          [[ -n "$claude_five_used" ]] || claude_five_used="n/a"
          [[ -n "$claude_five_reset_human" ]] || claude_five_reset_human="n/a"
        fi
        if [[ -f "$gemini_file" ]]; then
          gemini_tier="$(fuelcheck_field "$gemini_file" '.Gemini.tier')"
          gemini_flash_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_flash_reset_human="$(format_duration "$(seconds_until_iso "$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].resetTime)')")")"
          [[ -n "$gemini_tier" ]] || gemini_tier="n/a"
          [[ -n "$gemini_flash_used" ]] || gemini_flash_used="n/a"
          [[ -n "$gemini_flash_reset_human" ]] || gemini_flash_reset_human="n/a"
        fi
        if [[ ! -f "$codex_file" && ! -f "$claude_file" && ! -f "$gemini_file" ]]; then
          fuelcheck_status="unavailable"
        else
          fuelcheck_status="ok"
        fi
      fi
      printf '| %s | %s | %s | %s | %s | %s |\n' \
        "$candidate" \
        "$(printf 'plan=%s 5h=%s reset=%s' "$plan_type" "$primary_used" "$primary_reset_human")" \
        "$(printf 'plan=%s 5h=%s reset=%s' "$claude_plan" "$claude_five_used" "$claude_five_reset_human")" \
        "$(printf 'tier=%s flash=%s reset=%s' "$gemini_tier" "$gemini_flash_used" "$gemini_flash_reset_human")" \
        "$([[ "$candidate" == "$default_profile" ]] && printf 'yes' || printf 'no')" \
        "$fuelcheck_status"
    done < <(iterate_target_profiles "$workspace" "$profile" "$all")
  } >"$report_md"

  printf 'Wrote %s\n' "$report_json"
  printf 'Wrote %s\n' "$report_md"
}

cmd_status() {
  local profile=""
  local workspace=""
  local all="false"
  local requested_adapter="auto"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --adapter)
        requested_adapter="$2"
        shift 2
        ;;
      *)
        if [[ -z "$profile" ]]; then
          profile="$1"
          shift
        else
          fail "unknown option for status: $1"
        fi
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local adapter
  adapter="$(resolve_status_adapter "$requested_adapter" "$workspace")"

  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  print_status_table_header
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    status_for_profile "$workspace" "$candidate" "$default_profile" "$adapter"
  done < <(iterate_target_profiles "$workspace" "$profile" "$all")
}

cmd_doctor() {
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for doctor: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  printf 'Workspace: %s\n' "$workspace"
  if command -v codex >/dev/null 2>&1; then
    printf 'codex: %s\n' "$(command -v codex)"
  else
    printf 'codex: missing\n'
  fi
  if command -v jq >/dev/null 2>&1; then
    printf 'jq: %s\n' "$(command -v jq)"
  else
    printf 'jq: missing (optional)\n'
  fi
  if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
    printf 'fuelcheck: %s\n' "$(find_fuelcheck_bin "$workspace")"
  else
    printf 'fuelcheck: missing (managed dependency not installed; rerun init without --skip-fuelcheck or install it manually)\n'
  fi
  printf 'provider roots:\n'
  cmd_provider_root_list --workspace "$workspace" || true
  printf 'profiles:\n'
  cmd_profile_list --workspace "$workspace" || true
}

main() {
  local command="${1:-}"
  [[ -n "$command" ]] || {
    usage
    exit 1
  }
  shift || true

  case "$command" in
    init)
      cmd_init "$@"
      ;;
    profile)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        add) cmd_profile_add "$@" ;;
        list) cmd_profile_list "$@" ;;
        *) fail "unknown profile subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    provider-root)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        set) cmd_provider_root_set "$@" ;;
        list) cmd_provider_root_list "$@" ;;
        *) fail "unknown provider-root subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    use)
      cmd_use "$@"
      ;;
    login)
      cmd_login "$@"
      ;;
    run)
      cmd_run "$@"
      ;;
    preflight)
      cmd_preflight "$@"
      ;;
    codex)
      cmd_codex "$@"
      ;;
    mcp-server)
      cmd_mcp_server "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    report)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        status) cmd_report_status "$@" ;;
        *) fail "unknown report subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
