#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_TEMPLATE_DIR="$REPO_ROOT/templates/workspace"
PROFILE_TEMPLATE_DIR="$REPO_ROOT/templates/profile"
STATUS_REPORT_SCHEMA_VERSION="1"
EXECUTION_ARTIFACT_SCHEMA_VERSION="1"
USAGE_MAP_SCHEMA_VERSION="1"
USAGE_SNAPSHOT_SCHEMA_VERSION="1"

usage() {
  cat <<'EOF'
Usage:
  multiplus init [--skip-fuelcheck] <target>
  multiplus worktree create --repo <repo> --branch <branch> --path <path> --account <name> [--skip-fuelcheck]
  multiplus worktree list --repo <repo>
  multiplus worktree doctor --path <path>
  multiplus usage map --all [--workspace <dir>] [--output-dir <dir>]
  multiplus usage map --repo <repo> [--output-dir <dir>]
  multiplus usage snapshot --all --workspace <dir> [--output-dir <dir>]
  multiplus profile add <name> [--workspace <dir>]
  multiplus profile list [--workspace <dir>]
  multiplus provider-root set <provider> <path> [--workspace <dir>]
  multiplus provider-root list [--workspace <dir>]
  multiplus use <name> [--workspace <dir>]
  multiplus login <name> [--workspace <dir>] [-- codex-login-args...]
  multiplus run [<name>] [--workspace <dir>] [-- codex-args...]
  multiplus codex --account <name> [--workspace <dir>] [--write-artifact] [--artifact-dir <dir>] [-- codex-args...]
  multiplus status [<name>] [--all] [--workspace <dir>] [--adapter <auto|codex|fuelcheck>]
  multiplus report status [<name>] [--all] [--workspace <dir>] [--adapter <auto|codex|fuelcheck>] [--output-dir <dir>]
  multiplus doctor [--workspace <dir>] [--account <name>]

Environment:
  FUELCHECK_BIN                 Explicit fuelcheck binary path
  MULTIPLUS_CODEX_HOME          Override Codex auth root
  MULTIPLUS_CLAUDE_HOME         Override Claude auth root
  MULTIPLUS_GEMINI_HOME         Override Gemini auth root

Routing semantics:
  account                       Selects the isolated MultiPlus Codex home
  codex --profile               Selects a native Codex config profile inside that home
  --write-artifact              Writes execution metadata to .codex-home/artifacts/execution/
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

format_duration() {
  local total="${1:-}"
  if [[ -z "$total" || ! "$total" =~ ^[0-9]+$ ]]; then
    return 0
  fi

  local days hours minutes seconds remainder
  days=$(( total / 86400 ))
  remainder=$(( total % 86400 ))
  hours=$(( remainder / 3600 ))
  remainder=$(( remainder % 3600 ))
  minutes=$(( remainder / 60 ))
  seconds=$(( remainder % 60 ))

  printf '%dd:%02dh:%02dm:%02ds' "$days" "$hours" "$minutes" "$seconds"
}

seconds_until_iso() {
  local iso="${1:-}"
  [[ -n "$iso" ]] || return 0
  local now epoch
  now="$(date -u +%s 2>/dev/null || true)"
  epoch="$(date -u -d "$iso" +%s 2>/dev/null || true)"
  if [[ -n "$now" && -n "$epoch" && "$epoch" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
    if (( epoch > now )); then
      printf '%s' "$(( epoch - now ))"
    else
      printf '0'
    fi
  fi
}

abspath() {
  local target="$1"
  if [[ -d "$target" ]]; then
    (cd "$target" && pwd)
  else
    local parent
    parent="$(cd "$(dirname "$target")" && pwd)"
    printf '%s/%s\n' "$parent" "$(basename "$target")"
  fi
}

workspace_state_dir() {
  local workspace="$1"
  printf '%s/.codex-home/state\n' "$workspace"
}

workspace_profiles_dir() {
  local workspace="$1"
  printf '%s/.codex-home/profiles\n' "$workspace"
}

workspace_default_file() {
  local workspace="$1"
  printf '%s/default-profile\n' "$(workspace_state_dir "$workspace")"
}

worktree_meta_file() {
  local workspace="$1"
  printf '%s/worktree-link.json\n' "$(workspace_state_dir "$workspace")"
}

provider_roots_file() {
  local workspace="$1"
  printf '%s/provider-roots.env\n' "$(workspace_state_dir "$workspace")"
}

resolve_workspace() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    abspath "$explicit"
    return
  fi
  pwd
}

ensure_workspace_layout() {
  local workspace="$1"
  [[ -d "$workspace/.codex-home" ]] || fail "workspace is not initialized: $workspace"
}

bootstrap_workspace_files() {
  local workspace="$1"
  local skip_fuelcheck="${2:-false}"

  mkdir -p "$workspace/.codex" "$workspace/.codex-home/profiles" "$workspace/.codex-home/state"

  if [[ ! -f "$workspace/.codex/config.toml" ]]; then
    mkdir -p "$workspace/.codex"
    cp "$WORKSPACE_TEMPLATE_DIR/.codex/config.toml" "$workspace/.codex/config.toml"
    replace_placeholder "$workspace/.codex/config.toml" "__WORKSPACE_ROOT__" "$workspace"
  fi

  if [[ ! -f "$workspace/multiplus-local.sh" ]]; then
    cp "$WORKSPACE_TEMPLATE_DIR/multiplus-local.sh" "$workspace/multiplus-local.sh"
    replace_placeholder "$workspace/multiplus-local.sh" "__WORKSPACE_ROOT__" "$workspace"
    chmod +x "$workspace/multiplus-local.sh"
  fi

  if [[ ! -f "$workspace/AGENTS.md" ]]; then
    cp "$WORKSPACE_TEMPLATE_DIR/AGENTS.md" "$workspace/AGENTS.md"
  fi

  if [[ "$skip_fuelcheck" != "true" ]]; then
    install_managed_fuelcheck "$workspace"
  fi
}

profile_home() {
  local workspace="$1"
  local profile="$2"
  printf '%s/%s\n' "$(workspace_profiles_dir "$workspace")" "$profile"
}

account_home() {
  local workspace="$1"
  local account="$2"
  profile_home "$workspace" "$account"
}

profile_meta_file() {
  local workspace="$1"
  local profile="$2"
  printf '%s/.codex-home-profile\n' "$(profile_home "$workspace" "$profile")"
}

profile_config_file() {
  local workspace="$1"
  local profile="$2"
  printf '%s/.codex/config.toml\n' "$(profile_home "$workspace" "$profile")"
}

profile_exists() {
  local workspace="$1"
  local profile="$2"
  [[ -d "$(profile_home "$workspace" "$profile")" ]]
}

account_exists() {
  local workspace="$1"
  local account="$2"
  profile_exists "$workspace" "$account"
}

set_profile_env() {
  local workspace="$1"
  local profile="$2"
  local home_dir
  home_dir="$(profile_home "$workspace" "$profile")"
  export HOME="$home_dir"
  export XDG_CONFIG_HOME="$home_dir/.config"
  export XDG_CACHE_HOME="$home_dir/.cache"
  export XDG_DATA_HOME="$home_dir/.local/share"
}

resolve_account_name() {
  local workspace="$1"
  local candidate="${2:-}"
  local allow_default="${3:-false}"
  local account="$candidate"

  if [[ -z "$account" && "$allow_default" == "true" ]]; then
    account="$(read_default_profile "$workspace")"
  fi

  [[ -n "$account" ]] || fail "no account specified and no default profile set"
  account_exists "$workspace" "$account" || fail "unknown account: $account"
  printf '%s\n' "$account"
}

resolve_account_context() {
  local workspace_input="${1:-}"
  local candidate="${2:-}"
  local allow_default="${3:-false}"
  local workspace account home_dir is_default default_profile

  workspace="$(resolve_workspace "$workspace_input")"
  ensure_workspace_layout "$workspace"
  account="$(resolve_account_name "$workspace" "$candidate" "$allow_default")"
  home_dir="$(account_home "$workspace" "$account")"
  default_profile="$(read_default_profile "$workspace")"
  is_default="false"
  if [[ -n "$default_profile" && "$account" == "$default_profile" ]]; then
    is_default="true"
  fi

  printf '%s\t%s\t%s\t%s\n' "$workspace" "$account" "$home_dir" "$is_default"
}

extract_requested_codex_profile() {
  local args=("$@")
  local i=0
  while (( i < ${#args[@]} )); do
    case "${args[$i]}" in
      --profile)
        if (( i + 1 < ${#args[@]} )); then
          printf '%s\n' "${args[$((i + 1))]}"
          return 0
        fi
        return 0
        ;;
      --profile=*)
        printf '%s\n' "${args[$i]#--profile=}"
        return 0
        ;;
    esac
    i=$(( i + 1 ))
  done
}

codex_profile_exists_in_account() {
  local workspace="$1"
  local account="$2"
  local codex_profile="$3"
  local config_file
  config_file="$(profile_config_file "$workspace" "$account")"
  [[ -f "$config_file" ]] || return 1
  rg -q "^\\[profiles\\.${codex_profile//./\\.}\\]$" "$config_file"
}

validate_requested_codex_profile() {
  local workspace="$1"
  local account="$2"
  shift 2
  local requested_profile
  requested_profile="$(extract_requested_codex_profile "$@")"
  [[ -n "$requested_profile" ]] || return 0
  codex_profile_exists_in_account "$workspace" "$account" "$requested_profile" || fail "requested Codex profile not defined in selected account: $requested_profile"
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  cp -R "$src"/. "$dest"/
}

replace_placeholder() {
  local file="$1"
  local needle="$2"
  local value="$3"
  NEEDLE="$needle" VALUE="$value" perl -0pi -e 's/\Q$ENV{NEEDLE}\E/$ENV{VALUE}/g' "$file"
}

write_default_profile() {
  local workspace="$1"
  local profile="$2"
  mkdir -p "$(workspace_state_dir "$workspace")"
  printf '%s\n' "$profile" >"$(workspace_default_file "$workspace")"
}

read_default_profile() {
  local workspace="$1"
  local default_file
  default_file="$(workspace_default_file "$workspace")"
  if [[ -f "$default_file" ]]; then
    tr -d '\n' <"$default_file"
  fi
}

list_profiles() {
  local workspace="$1"
  local dir
  dir="$(workspace_profiles_dir "$workspace")"
  if [[ -d "$dir" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
  fi
}

normalize_provider_name() {
  local provider="${1:-}"
  case "$provider" in
    codex|claude|gemini) printf '%s\n' "$provider" ;;
    *) fail "unknown provider: $provider" ;;
  esac
}

provider_root_env_name() {
  local provider="$1"
  printf 'MULTIPLUS_%s_HOME\n' "$(printf '%s' "$provider" | tr '[:lower:]' '[:upper:]')"
}

read_provider_root_config() {
  local workspace="$1"
  local provider="$2"
  local file key
  file="$(provider_roots_file "$workspace")"
  key="$(provider_root_env_name "$provider")"
  if [[ -f "$file" ]]; then
    awk -F= -v key="$key" '$1==key {sub(/^[^=]*=/,""); print; exit}' "$file"
  fi
}

resolve_provider_root() {
  local workspace="$1"
  local provider="$2"
  local default_root="$3"
  local env_name config_value env_value
  env_name="$(provider_root_env_name "$provider")"
  env_value="${!env_name:-}"
  if [[ -n "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return
  fi
  config_value="$(read_provider_root_config "$workspace" "$provider")"
  if [[ -n "$config_value" ]]; then
    printf '%s\n' "$config_value"
    return
  fi
  printf '%s\n' "$default_root"
}

write_provider_root_config() {
  local workspace="$1"
  local provider="$2"
  local root="$3"
  local file key tmp
  mkdir -p "$(workspace_state_dir "$workspace")"
  file="$(provider_roots_file "$workspace")"
  key="$(provider_root_env_name "$provider")"
  tmp="$(mktemp)"
  if [[ -f "$file" ]]; then
    awk -F= -v key="$key" '$1!=key {print}' "$file" >"$tmp"
  fi
  printf '%s=%s\n' "$key" "$root" >>"$tmp"
  mv "$tmp" "$file"
}

cmd_provider_root_set() {
  local provider="${1:-}"
  local root="${2:-}"
  shift 2 || true
  provider="$(normalize_provider_name "$provider")"
  [[ -n "$root" ]] || fail "provider-root set requires a path"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for provider-root set: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  write_provider_root_config "$workspace" "$provider" "$(abspath "$root")"
  printf 'Provider root set: %s -> %s\n' "$provider" "$(read_provider_root_config "$workspace" "$provider")"
}

cmd_provider_root_list() {
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for provider-root list: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local provider root
  for provider in codex claude gemini; do
    root="$(resolve_provider_root "$workspace" "$provider" "")"
    if [[ -n "$root" ]]; then
      printf '%s %s\n' "$provider" "$root"
    else
      printf '%s (default)\n' "$provider"
    fi
  done
}

print_status_table_header() {
  printf '%-16s %-24s %-12s %-10s %-s\n' "PROFILE" "AUTH" "SOURCE" "DEFAULT" "HOME"
}

print_status_row() {
  local profile="$1"
  local auth="$2"
  local source="$3"
  local is_default="$4"
  local home_dir="$5"
  printf '%-16s %-24s %-12s %-10s %-s\n' "$profile" "$auth" "$source" "$is_default" "$home_dir"
}

find_fuelcheck_bin() {
  local workspace="${1:-}"
  if [[ -n "${FUELCHECK_BIN:-}" && -x "${FUELCHECK_BIN}" ]]; then
    printf '%s\n' "$FUELCHECK_BIN"
    return 0
  fi
  if [[ -n "$workspace" ]]; then
    local managed_bin
    managed_bin="$(managed_fuelcheck_bin "$workspace")"
    if [[ -x "$managed_bin" ]]; then
      printf '%s\n' "$managed_bin"
      return 0
    fi
  fi
  if command -v fuelcheck >/dev/null 2>&1; then
    command -v fuelcheck
    return 0
  fi
  return 1
}

fuelcheck_supports_usage_subcommand() {
  local fuelcheck_bin="$1"
  "$fuelcheck_bin" usage --help >/dev/null 2>&1
}

managed_fuelcheck_root() {
  local workspace="$1"
  printf '%s/.codex-home/tools/fuelcheck\n' "$workspace"
}

managed_fuelcheck_bin() {
  local workspace="$1"
  printf '%s/bin/fuelcheck\n' "$(managed_fuelcheck_root "$workspace")"
}

managed_fuelcheck_cli_bin() {
  local workspace="$1"
  printf '%s/bin/fuelcheck-cli\n' "$(managed_fuelcheck_root "$workspace")"
}

ensure_managed_fuelcheck_entrypoint() {
  local workspace="$1"
  local managed_bin managed_cli_bin
  managed_bin="$(managed_fuelcheck_bin "$workspace")"
  managed_cli_bin="$(managed_fuelcheck_cli_bin "$workspace")"

  if [[ -x "$managed_bin" ]]; then
    return 0
  fi

  if [[ -x "$managed_cli_bin" ]]; then
    cat >"$managed_bin" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/fuelcheck-cli" "$@"
EOF
    chmod +x "$managed_bin"
    return 0
  fi

  return 1
}

install_managed_fuelcheck() {
  local workspace="$1"
  local managed_root managed_bin
  if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v cargo >/dev/null 2>&1; then
    fail "fuelcheck is required by default but cargo is missing; install cargo or rerun init with --skip-fuelcheck"
  fi
  managed_root="$(managed_fuelcheck_root "$workspace")"
  managed_bin="$(managed_fuelcheck_bin "$workspace")"
  mkdir -p "$managed_root"
  if ! cargo install fuelcheck-cli --root "$managed_root"; then
    fail "failed to install fuelcheck; rerun init with --skip-fuelcheck to continue without it"
  fi
  ensure_managed_fuelcheck_entrypoint "$workspace" || fail "fuelcheck install completed without a usable binary at $managed_bin"
  [[ -x "$managed_bin" ]] || fail "fuelcheck install completed without a usable binary at $managed_bin"
  printf 'Installed managed fuelcheck at %s\n' "$managed_bin"
}

resolve_status_adapter() {
  local requested="$1"
  local workspace="${2:-}"
  case "$requested" in
    auto)
      if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
        printf 'fuelcheck\n'
      else
        printf 'codex\n'
      fi
      ;;
    codex|fuelcheck)
      printf '%s\n' "$requested"
      ;;
    *)
      fail "unknown adapter: $requested"
      ;;
  esac
}

collect_codex_login_status() {
  local auth="not logged in"
  if command -v codex >/dev/null 2>&1; then
    auth="$(codex login status 2>&1 || true)"
    [[ -n "$auth" ]] || auth="status unavailable"
  else
    auth="codex missing"
  fi
  printf '%s\n' "$auth"
}

auth_status_ok() {
  local auth="${1:-}"
  [[ "$auth" == Logged\ in* ]]
}

run_account_preflight() {
  local workspace_input="${1:-}"
  local account="${2:-}"
  local require_auth="${3:-true}"
  local context workspace resolved_account home_dir auth ok

  context="$(resolve_account_context "$workspace_input" "$account" "false")"
  workspace="${context%%$'\t'*}"
  context="${context#*$'\t'}"
  resolved_account="${context%%$'\t'*}"
  context="${context#*$'\t'}"
  home_dir="${context%%$'\t'*}"

  ok="true"
  if ! command -v codex >/dev/null 2>&1; then
    ok="false"
  fi
  if [[ ! -d "$home_dir" || ! -d "$home_dir/.codex" ]]; then
    ok="false"
  fi

  auth="codex missing"
  if command -v codex >/dev/null 2>&1; then
    set_profile_env "$workspace" "$resolved_account"
    auth="$(collect_codex_login_status)"
    if [[ "$require_auth" == "true" ]] && ! auth_status_ok "$auth"; then
      ok="false"
    fi
  fi

  printf '%s\t%s\t%s\t%s\n' "$resolved_account" "$home_dir" "$auth" "$ok"
}

collect_fuelcheck_json() {
  local provider="$1"
  local home_root="$2"
  local workspace="${3:-}"
  local fuelcheck_bin
  fuelcheck_bin="$(find_fuelcheck_bin "$workspace")" || return 1
  if fuelcheck_supports_usage_subcommand "$fuelcheck_bin"; then
    HOME="$home_root" \
    XDG_CONFIG_HOME="$home_root/.config" \
    XDG_CACHE_HOME="$home_root/.cache" \
    XDG_DATA_HOME="$home_root/.local/share" \
    "$fuelcheck_bin" usage -p "$provider" --format json --json-only 2>/dev/null
  else
    HOME="$home_root" \
    XDG_CONFIG_HOME="$home_root/.config" \
    XDG_CACHE_HOME="$home_root/.cache" \
    XDG_DATA_HOME="$home_root/.local/share" \
    "$fuelcheck_bin" "$provider" --json 2>/dev/null
  fi
}

fuelcheck_field() {
  local json_file="$1"
  local jq_filter="$2"
  if command -v jq >/dev/null 2>&1 && [[ -f "$json_file" ]]; then
    jq -r "($jq_filter) | if . == null then empty else . end" "$json_file" 2>/dev/null || true
  fi
}

print_json_string_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": "%s",\n' "$key" "$(json_escape "$value")"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

print_json_number_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": %s,\n' "$key" "$value"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

print_json_bool_or_null() {
  local key="$1"
  local value="${2:-}"
  if [[ -n "$value" ]]; then
    printf '        "%s": %s,\n' "$key" "$value"
  else
    printf '        "%s": null,\n' "$key"
  fi
}

status_snapshot() {
  local workspace="$1"
  local profile="$2"
  local adapter="$3"
  set_profile_env "$workspace" "$profile"

  local auth source fuelcheck_json
  auth="$(collect_codex_login_status)"
  source="codex"

  if [[ "$adapter" == "fuelcheck" ]]; then
    if fuelcheck_json="$(collect_fuelcheck_json codex "$(resolve_provider_root "$workspace" codex "$(profile_home "$workspace" "$profile")")" "$workspace")"; then
      source="fuelcheck"
    else
      source="codex-fallback"
    fi
  fi

  printf '%s\t%s\n' "$auth" "$source"
}

cmd_init() {
  local target=""
  local skip_fuelcheck="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-fuelcheck)
        skip_fuelcheck="true"
        shift
        ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
          shift
        else
          fail "unknown option for init: $1"
        fi
        ;;
    esac
  done
  [[ -n "$target" ]] || fail "init requires a target path"
  local workspace
  workspace="$(abspath "$target")"
  mkdir -p "$workspace"

  copy_dir_contents "$WORKSPACE_TEMPLATE_DIR" "$workspace"
  mkdir -p "$workspace/.codex-home/profiles" "$workspace/.codex-home/state"

  replace_placeholder "$workspace/.codex/config.toml" "__WORKSPACE_ROOT__" "$workspace"
  replace_placeholder "$workspace/multiplus-local.sh" "__WORKSPACE_ROOT__" "$workspace"

  if [[ "$skip_fuelcheck" != "true" ]]; then
    install_managed_fuelcheck "$workspace"
  fi

  printf 'Initialized workspace at %s\n' "$workspace"
  printf 'Next steps:\n'
  printf '  %s profile add personal --workspace %s\n' "$0" "$workspace"
  printf '  %s login personal --workspace %s\n' "$0" "$workspace"
}

write_worktree_metadata() {
  local workspace="$1"
  local repo="$2"
  local branch="$3"
  local account="$4"
  local created_at="$5"
  local metadata_file
  metadata_file="$(worktree_meta_file "$workspace")"
  mkdir -p "$(dirname "$metadata_file")"
  cat >"$metadata_file" <<EOF
{
  "schema_version": "1",
  "repo": "$(json_escape "$repo")",
  "worktree": "$(json_escape "$workspace")",
  "branch": "$(json_escape "$branch")",
  "account": "$(json_escape "$account")",
  "created_at": "$(json_escape "$created_at")"
}
EOF
}

git_repo_root() {
  local repo="$1"
  git -C "$repo" rev-parse --show-toplevel 2>/dev/null
}

git_common_repo_root() {
  local repo="$1"
  local common_dir
  common_dir="$(git -C "$repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
  if [[ "$common_dir" == */.git ]]; then
    dirname "$common_dir"
  else
    git_repo_root "$repo"
  fi
}

worktree_metadata_field() {
  local metadata_file="$1"
  local key="$2"
  [[ -f "$metadata_file" ]] || return 1
  sed -n "s/^[[:space:]]*\"$key\": \"\\(.*\\)\"[,]\\{0,1\\}$/\\1/p" "$metadata_file" | head -n 1
}

git_worktree_branch() {
  local worktree_path="$1"
  local branch
  branch="$(git -C "$worktree_path" branch --show-current 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    printf '%s\n' "$branch"
  else
    printf 'detached\n'
  fi
}

list_git_worktrees() {
  local repo_root="$1"
  git -C "$repo_root" worktree list --porcelain | awk '
    BEGIN {
      worktree = ""
      branch = "detached"
    }
    /^worktree / {
      if (worktree != "") {
        print worktree "\t" branch
      }
      worktree = substr($0, 10)
      branch = "detached"
      next
    }
    /^branch / {
      branch = substr($0, 8)
      sub(/^refs\/heads\//, "", branch)
      next
    }
    /^$/ {
      if (worktree != "") {
        print worktree "\t" branch
        worktree = ""
        branch = "detached"
      }
      next
    }
    END {
      if (worktree != "") {
        print worktree "\t" branch
      }
    }
  '
}

print_worktree_list_header() {
  printf '%-10s %-24s %-16s %-16s %-s\n' "STATUS" "BRANCH" "ACCOUNT" "WORKTREE" "CODEX_HOME"
}

print_worktree_list_row() {
  local status="$1"
  local branch="$2"
  local account="$3"
  local worktree_path="$4"
  local codex_home="$5"
  printf '%-10s %-24s %-16s %-16s %-s\n' "$status" "$branch" "$account" "$worktree_path" "$codex_home"
}

cmd_worktree_create() {
  local repo=""
  local branch=""
  local path=""
  local account=""
  local skip_fuelcheck="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo="$2"
        shift 2
        ;;
      --branch)
        branch="$2"
        shift 2
        ;;
      --path)
        path="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      --skip-fuelcheck)
        skip_fuelcheck="true"
        shift
        ;;
      *)
        fail "unknown option for worktree create: $1"
        ;;
    esac
  done

  [[ -n "$repo" ]] || fail "worktree create requires --repo <repo>"
  [[ -n "$branch" ]] || fail "worktree create requires --branch <branch>"
  [[ -n "$path" ]] || fail "worktree create requires --path <path>"
  [[ -n "$account" ]] || fail "worktree create requires --account <name>"
  require_cmd git

  local repo_root worktree_path created_at
  repo_root="$(git_repo_root "$repo")" || fail "repo is not a git repository: $repo"
  worktree_path="$(abspath "$path")"

  git -C "$repo_root" worktree add "$worktree_path" -b "$branch"

  bootstrap_workspace_files "$worktree_path" "$skip_fuelcheck"
  if ! profile_exists "$worktree_path" "$account"; then
    cmd_profile_add "$account" --workspace "$worktree_path"
  fi
  created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  write_worktree_metadata "$worktree_path" "$repo_root" "$branch" "$account" "$created_at"

  printf 'Created worktree %s\n' "$worktree_path"
  printf 'Repo: %s\n' "$repo_root"
  printf 'Branch: %s\n' "$branch"
  printf 'Account: %s\n' "$account"
  printf 'Next steps:\n'
  printf '  %s codex --account %s --workspace %s login status\n' "$0" "$account" "$worktree_path"
}

cmd_worktree_list() {
  local repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo="$2"
        shift 2
        ;;
      *)
        fail "unknown option for worktree list: $1"
        ;;
    esac
  done

  [[ -n "$repo" ]] || fail "worktree list requires --repo <repo>"
  require_cmd git

  local repo_root
  repo_root="$(git_repo_root "$repo")" || fail "repo is not a git repository: $repo"

  printf 'Repo: %s\n' "$repo_root"
  print_worktree_list_header

  local row worktree_path git_branch metadata_file metadata_repo metadata_worktree metadata_branch account status codex_home
  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    worktree_path="${row%%$'\t'*}"
    git_branch="${row#*$'\t'}"
    metadata_file="$(worktree_meta_file "$worktree_path")"
    account="-"
    codex_home="-"
    status="unlinked"

    if [[ -f "$metadata_file" ]]; then
      metadata_repo="$(worktree_metadata_field "$metadata_file" repo || true)"
      metadata_worktree="$(worktree_metadata_field "$metadata_file" worktree || true)"
      metadata_branch="$(worktree_metadata_field "$metadata_file" branch || true)"
      account="$(worktree_metadata_field "$metadata_file" account || true)"

      if [[ -z "$metadata_repo" || -z "$metadata_worktree" || -z "$metadata_branch" || -z "$account" ]]; then
        status="metadata-invalid"
        account="${account:-?}"
      elif [[ "$metadata_repo" != "$repo_root" ]]; then
        status="repo-mismatch"
      elif [[ "$metadata_worktree" != "$worktree_path" ]]; then
        status="path-mismatch"
      elif [[ "$metadata_branch" != "$git_branch" ]]; then
        status="branch-mismatch"
      elif ! account_exists "$worktree_path" "$account"; then
        status="account-missing"
      else
        status="linked"
      fi

      if [[ -n "$account" && "$account" != "?" ]]; then
        codex_home="$(account_home "$worktree_path" "$account")"
      fi
    fi

    print_worktree_list_row "$status" "$git_branch" "$account" "$worktree_path" "$codex_home"
  done < <(list_git_worktrees "$repo_root")
}

cmd_worktree_doctor() {
  local path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path)
        path="$2"
        shift 2
        ;;
      *)
        fail "unknown option for worktree doctor: $1"
        ;;
    esac
  done

  [[ -n "$path" ]] || fail "worktree doctor requires --path <path>"
  require_cmd git

  local worktree_path repo_root git_branch metadata_file metadata_repo metadata_worktree metadata_branch account
  local preflight resolved_account home_dir auth ok
  worktree_path="$(abspath "$path")"
  [[ -e "$worktree_path" ]] || fail "worktree path does not exist: $worktree_path"
  repo_root="$(git_common_repo_root "$worktree_path")" || fail "worktree path is not attached to a git worktree: $worktree_path"
  git_branch="$(git_worktree_branch "$worktree_path")"
  metadata_file="$(worktree_meta_file "$worktree_path")"
  [[ -f "$metadata_file" ]] || fail "worktree metadata missing: $metadata_file"

  metadata_repo="$(worktree_metadata_field "$metadata_file" repo || true)"
  metadata_worktree="$(worktree_metadata_field "$metadata_file" worktree || true)"
  metadata_branch="$(worktree_metadata_field "$metadata_file" branch || true)"
  account="$(worktree_metadata_field "$metadata_file" account || true)"

  [[ -n "$metadata_repo" && -n "$metadata_worktree" && -n "$metadata_branch" && -n "$account" ]] || fail "worktree metadata incomplete: $metadata_file"
  [[ "$metadata_worktree" == "$worktree_path" ]] || fail "worktree metadata path mismatch: expected $worktree_path, found $metadata_worktree"
  [[ "$metadata_repo" == "$repo_root" ]] || fail "worktree metadata repo mismatch: expected $repo_root, found $metadata_repo"
  [[ "$metadata_branch" == "$git_branch" ]] || fail "worktree metadata branch mismatch: expected $git_branch, found $metadata_branch"
  ensure_workspace_layout "$worktree_path"
  account_exists "$worktree_path" "$account" || fail "linked account missing for worktree: $account"

  preflight="$(run_account_preflight "$worktree_path" "$account" "true")"
  resolved_account="${preflight%%$'\t'*}"
  preflight="${preflight#*$'\t'}"
  home_dir="${preflight%%$'\t'*}"
  preflight="${preflight#*$'\t'}"
  auth="${preflight%%$'\t'*}"
  ok="${preflight##*$'\t'}"

  printf 'Worktree: %s\n' "$worktree_path"
  printf 'Repo: %s\n' "$repo_root"
  printf 'Branch: %s\n' "$git_branch"
  printf 'Metadata file: %s\n' "$metadata_file"
  printf 'Account: %s\n' "$resolved_account"
  printf 'Codex home: %s\n' "$home_dir"
  printf 'Auth: %s\n' "$auth"

  if [[ "$ok" == "true" ]]; then
    printf 'Doctor: ok\n'
    return 0
  fi

  if ! command -v codex >/dev/null 2>&1; then
    fail "worktree routed doctor failed: Codex CLI not installed"
  elif [[ ! -d "$home_dir" || ! -d "$home_dir/.codex" ]]; then
    fail "worktree routed doctor failed: Codex home missing for selected account"
  elif ! auth_status_ok "$auth"; then
    fail "worktree routed doctor failed: no active login for selected account"
  fi
  fail "worktree routed doctor failed for account: $resolved_account"
}

cmd_profile_add() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "profile add requires a profile name"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for profile add: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  local home_dir
  home_dir="$(profile_home "$workspace" "$profile")"
  if profile_exists "$workspace" "$profile"; then
    fail "profile already exists: $profile"
  fi

  copy_dir_contents "$PROFILE_TEMPLATE_DIR" "$home_dir"
  mkdir -p "$home_dir/.codex" "$home_dir/.config" "$home_dir/.cache" "$home_dir/.local/share"
  replace_placeholder "$home_dir/.codex/config.toml" "__WORKSPACE_ROOT__" "$workspace"
  replace_placeholder "$home_dir/.codex/config.toml" "__PROFILE_NAME__" "$profile"
  printf 'profile=%s\nworkspace=%s\n' "$profile" "$workspace" >"$(profile_meta_file "$workspace" "$profile")"

  if [[ -z "$(read_default_profile "$workspace")" ]]; then
    write_default_profile "$workspace" "$profile"
  fi

  printf 'Created profile %s at %s\n' "$profile" "$home_dir"
}

cmd_profile_list() {
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for profile list: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  while IFS= read -r profile; do
    [[ -n "$profile" ]] || continue
    if [[ "$profile" == "$default_profile" ]]; then
      printf '* %s\n' "$profile"
    else
      printf '  %s\n' "$profile"
    fi
  done < <(list_profiles "$workspace")
}

cmd_use() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "use requires a profile name"
  local workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      *)
        fail "unknown option for use: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  profile_exists "$workspace" "$profile" || fail "unknown profile: $profile"
  write_default_profile "$workspace" "$profile"
  printf 'Default profile set to %s\n' "$profile"
}

cmd_login() {
  local profile="${1:-}"
  shift || true
  [[ -n "$profile" ]] || fail "login requires a profile name"
  local workspace=""
  local extra_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --)
        shift
        extra_args=("$@")
        break
        ;;
      *)
        extra_args+=("$1")
        shift
        ;;
    esac
  done
  local context resolved_profile
  context="$(resolve_account_context "$workspace" "$profile" "false")"
  workspace="${context%%$'\t'*}"
  context="${context#*$'\t'}"
  resolved_profile="${context%%$'\t'*}"
  require_cmd codex
  set_profile_env "$workspace" "$resolved_profile"
  exec codex login "${extra_args[@]}"
}

resolve_run_profile() {
  local workspace="$1"
  local candidate="${2:-}"
  resolve_account_name "$workspace" "$candidate" "true"
}

cmd_run() {
  local maybe_profile=""
  local workspace=""
  local codex_args=()
  if [[ $# -gt 0 && "$1" != --* ]]; then
    maybe_profile="$1"
    shift
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --)
        shift
        codex_args=("$@")
        break
        ;;
      *)
        codex_args+=("$1")
        shift
        ;;
    esac
  done
  local profile
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  profile="$(resolve_run_profile "$workspace" "$maybe_profile")"
  validate_requested_codex_profile "$workspace" "$profile" "${codex_args[@]}"
  require_cmd codex
  set_profile_env "$workspace" "$profile"
  exec codex -C "$workspace" "${codex_args[@]}"
}

cmd_codex() {
  local workspace=""
  local account=""
  local write_artifact="false"
  local artifact_dir=""
  local codex_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      --write-artifact)
        write_artifact="true"
        shift
        ;;
      --artifact-dir)
        artifact_dir="$2"
        shift 2
        ;;
      --)
        shift
        codex_args=("$@")
        break
        ;;
      *)
        codex_args+=("$1")
        shift
        ;;
    esac
  done

  [[ -n "$account" ]] || fail "codex requires --account <name>"
  local preflight resolved_account home_dir auth ok
  preflight="$(run_account_preflight "$workspace" "$account" "true")"
  resolved_account="${preflight%%$'\t'*}"
  preflight="${preflight#*$'\t'}"
  home_dir="${preflight%%$'\t'*}"
  preflight="${preflight#*$'\t'}"
  auth="${preflight%%$'\t'*}"
  ok="${preflight##*$'\t'}"

  if [[ "$ok" != "true" ]]; then
    if ! command -v codex >/dev/null 2>&1; then
      fail "Codex CLI not installed"
    elif [[ ! -d "$home_dir" || ! -d "$home_dir/.codex" ]]; then
      fail "Codex home missing for selected account"
    elif ! auth_status_ok "$auth"; then
      fail "no active login for selected account"
    else
      fail "preflight failed for account: $resolved_account"
    fi
  fi

  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  validate_requested_codex_profile "$workspace" "$resolved_account" "${codex_args[@]}"
  local codex_profile
  codex_profile="$(extract_requested_codex_profile "${codex_args[@]}")"
  if [[ "$write_artifact" == "true" && -z "$artifact_dir" ]]; then
    artifact_dir="$(execution_artifact_dir "$workspace")"
  fi
  if [[ -n "$artifact_dir" ]]; then
    artifact_dir="$(abspath "$artifact_dir")"
  fi
  set_profile_env "$workspace" "$resolved_account"
  if [[ "$write_artifact" == "true" ]]; then
    local generated_at exit_code artifact_file executed_command
    generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    executed_command=(-C "$workspace" "${codex_args[@]}")
    set +e
    codex "${executed_command[@]}"
    exit_code=$?
    set -e
    artifact_file="$(write_execution_artifact "$artifact_dir" "$generated_at" "$workspace" "$resolved_account" "$home_dir" "$auth" "true" "$exit_code" "$codex_profile" "${executed_command[@]}")"
    printf 'Wrote %s\n' "$artifact_file" >&2
    exit "$exit_code"
  fi
  exec codex -C "$workspace" "${codex_args[@]}"
}

status_for_profile() {
  local workspace="$1"
  local profile="$2"
  local default_profile="$3"
  local adapter="$4"
  local snapshot auth source
  snapshot="$(status_snapshot "$workspace" "$profile" "$adapter")"
  auth="${snapshot%%$'\t'*}"
  source="${snapshot#*$'\t'}"
  local is_default="no"
  if [[ "$profile" == "$default_profile" ]]; then
    is_default="yes"
  fi
  print_status_row "$profile" "$auth" "$source" "$is_default" "$(profile_home "$workspace" "$profile")"
}

iterate_target_profiles() {
  local workspace="$1"
  local profile="$2"
  local all="$3"
  local default_profile
  default_profile="$(read_default_profile "$workspace")"

  if [[ "$all" == "true" ]]; then
    list_profiles "$workspace"
    return
  fi

  if [[ -z "$profile" ]]; then
    profile="$default_profile"
  fi
  resolve_account_name "$workspace" "$profile" "false"
}

write_text_file() {
  local file="$1"
  local value="$2"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" >"$file"
}

execution_artifact_dir() {
  local workspace="$1"
  printf '%s/.codex-home/artifacts/execution\n' "$workspace"
}

usage_artifact_dir() {
  local workspace="$1"
  printf '%s/.codex-home/artifacts/usage\n' "$workspace"
}

usage_map_json_path() {
  local output_dir="$1"
  printf '%s/usage-map.json\n' "$output_dir"
}

usage_map_markdown_path() {
  local output_dir="$1"
  printf '%s/usage-map.md\n' "$output_dir"
}

usage_snapshot_json_path() {
  local output_dir="$1"
  printf '%s/usage-snapshot.json\n' "$output_dir"
}

usage_snapshot_markdown_path() {
  local output_dir="$1"
  printf '%s/usage-snapshot.md\n' "$output_dir"
}

emit_usage_map_row() {
  local sep=$'\037'
  local kind="$1"
  local link_status="$2"
  local repo_root="$3"
  local branch="$4"
  local workspace="$5"
  local worktree_path="$6"
  local linked_account="$7"
  local default_profile="$8"
  local codex_home="$9"
  local status_source="${10}"
  local last_updated="${11}"
  printf '%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s\n' \
    "$kind" "$sep" "$link_status" "$sep" "$repo_root" "$sep" "$branch" "$sep" "$workspace" "$sep" \
    "$worktree_path" "$sep" "$linked_account" "$sep" "$default_profile" "$sep" "$codex_home" "$sep" "$status_source" "$sep" "$last_updated"
}

status_source_for_profile() {
  local workspace="$1"
  local profile="$2"
  local snapshot
  snapshot="$(status_snapshot "$workspace" "$profile" "auto")"
  printf '%s\n' "${snapshot#*$'\t'}"
}

emit_usage_snapshot_row() {
  local sep=$'\037'
  local kind="$1"
  local link_status="$2"
  local repo_root="$3"
  local branch="$4"
  local workspace="$5"
  local worktree_path="$6"
  local linked_account="$7"
  local default_profile="$8"
  local codex_home="$9"
  local auth_status="${10}"
  local status_source="${11}"
  local five_hour_used="${12}"
  local five_hour_reset_human="${13}"
  local weekly_used="${14}"
  local weekly_reset_human="${15}"
  printf '%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s\n' \
    "$kind" "$sep" "$link_status" "$sep" "$repo_root" "$sep" "$branch" "$sep" "$workspace" "$sep" \
    "$worktree_path" "$sep" "$linked_account" "$sep" "$default_profile" "$sep" "$codex_home" "$sep" \
    "$auth_status" "$sep" "$status_source" "$sep" "$five_hour_used" "$sep" "$five_hour_reset_human" "$sep" \
    "$weekly_used" "$sep" "$weekly_reset_human"
}

collect_codex_usage_metrics() {
  local workspace="$1"
  local profile="$2"
  local adapter="$3"
  local codex_root fuelcheck_raw codex_file
  local five_hour_used="" five_hour_reset="" five_hour_reset_at="" five_hour_reset_human=""
  local weekly_used="" weekly_reset="" weekly_reset_at="" weekly_reset_human=""

  if [[ "$adapter" != "fuelcheck" ]]; then
    printf '\t\t\t\n'
    return 0
  fi

  codex_root="$(resolve_provider_root "$workspace" codex "$(profile_home "$workspace" "$profile")")"
  if fuelcheck_raw="$(collect_fuelcheck_json codex "$codex_root" "$workspace")"; then
    codex_file="$(mktemp)"
    write_text_file "$codex_file" "$fuelcheck_raw"
    five_hour_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.used_percent // .[0].usage.primary.usedPercent')"
    five_hour_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.reset_after_seconds')"
    five_hour_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.primary.resetsAt')"
    weekly_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.used_percent // .[0].usage.secondary.usedPercent')"
    weekly_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.reset_after_seconds')"
    weekly_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.secondary.resetsAt')"
    rm -f "$codex_file"
    if [[ -z "$five_hour_reset" && -n "$five_hour_reset_at" ]]; then
      five_hour_reset="$(seconds_until_iso "$five_hour_reset_at")"
    fi
    if [[ -z "$weekly_reset" && -n "$weekly_reset_at" ]]; then
      weekly_reset="$(seconds_until_iso "$weekly_reset_at")"
    fi
    five_hour_reset_human="$(format_duration "$five_hour_reset")"
    weekly_reset_human="$(format_duration "$weekly_reset")"
  fi

  printf '%s\t%s\t%s\t%s\n' "$five_hour_used" "$five_hour_reset_human" "$weekly_used" "$weekly_reset_human"
}

usage_map_for_workspace() {
  local workspace="$1"
  ensure_workspace_layout "$workspace"

  local default_profile linked_account codex_home status_source metadata_file last_updated repo_root branch kind
  default_profile="$(read_default_profile "$workspace")"
  linked_account=""
  codex_home=""
  status_source="unavailable"
  metadata_file="$(worktree_meta_file "$workspace")"
  last_updated=""
  repo_root=""
  branch=""
  kind="workspace"

  if [[ -n "$default_profile" && -d "$(profile_home "$workspace" "$default_profile")" ]]; then
    codex_home="$(profile_home "$workspace" "$default_profile")"
    status_source="$(status_source_for_profile "$workspace" "$default_profile")"
  fi

  if [[ -f "$metadata_file" ]]; then
    kind="worktree"
    linked_account="$(worktree_metadata_field "$metadata_file" account || true)"
    last_updated="$(worktree_metadata_field "$metadata_file" created_at || true)"
    repo_root="$(worktree_metadata_field "$metadata_file" repo || true)"
    branch="$(worktree_metadata_field "$metadata_file" branch || true)"
    if [[ -n "$linked_account" && -d "$(profile_home "$workspace" "$linked_account")" ]]; then
      codex_home="$(profile_home "$workspace" "$linked_account")"
    fi
    emit_usage_map_row "$kind" "linked" "$repo_root" "$branch" "$workspace" "$workspace" "$linked_account" "$default_profile" "$codex_home" "$status_source" "$last_updated"
    return 0
  fi

  if repo_root="$(git_common_repo_root "$workspace" 2>/dev/null)"; then
    branch="$(git_worktree_branch "$workspace")"
  else
    repo_root=""
    branch=""
  fi

  emit_usage_map_row "$kind" "workspace" "$repo_root" "$branch" "$workspace" "" "" "$default_profile" "$codex_home" "$status_source" ""
}

usage_snapshot_for_workspace() {
  local workspace="$1"
  ensure_workspace_layout "$workspace"

  local default_profile linked_account codex_home auth_status status_source metadata_file repo_root branch kind metrics
  local adapter
  local five_hour_used five_hour_reset_human weekly_used weekly_reset_human
  default_profile="$(read_default_profile "$workspace")"
  linked_account=""
  codex_home=""
  auth_status="status unavailable"
  status_source="unavailable"
  metadata_file="$(worktree_meta_file "$workspace")"
  repo_root=""
  branch=""
  kind="workspace"
  five_hour_used=""
  five_hour_reset_human=""
  weekly_used=""
  weekly_reset_human=""

  if [[ -n "$default_profile" && -d "$(profile_home "$workspace" "$default_profile")" ]]; then
    codex_home="$(profile_home "$workspace" "$default_profile")"
    set_profile_env "$workspace" "$default_profile"
    auth_status="$(collect_codex_login_status)"
    adapter="$(resolve_status_adapter "auto" "$workspace")"
    status_source="$adapter"
    metrics="$(collect_codex_usage_metrics "$workspace" "$default_profile" "$adapter")"
    five_hour_used="${metrics%%$'\t'*}"
    metrics="${metrics#*$'\t'}"
    five_hour_reset_human="${metrics%%$'\t'*}"
    metrics="${metrics#*$'\t'}"
    weekly_used="${metrics%%$'\t'*}"
    weekly_reset_human="${metrics##*$'\t'}"
  fi

  if [[ -f "$metadata_file" ]]; then
    kind="worktree"
    linked_account="$(worktree_metadata_field "$metadata_file" account || true)"
    repo_root="$(worktree_metadata_field "$metadata_file" repo || true)"
    branch="$(worktree_metadata_field "$metadata_file" branch || true)"
    emit_usage_snapshot_row "$kind" "linked" "$repo_root" "$branch" "$workspace" "$workspace" "$linked_account" "$default_profile" "$codex_home" "$auth_status" "$status_source" "$five_hour_used" "$five_hour_reset_human" "$weekly_used" "$weekly_reset_human"
    return 0
  fi

  if repo_root="$(git_common_repo_root "$workspace" 2>/dev/null)"; then
    branch="$(git_worktree_branch "$workspace")"
  else
    repo_root=""
    branch=""
  fi

  emit_usage_snapshot_row "$kind" "workspace" "$repo_root" "$branch" "$workspace" "" "" "$default_profile" "$codex_home" "$auth_status" "$status_source" "$five_hour_used" "$five_hour_reset_human" "$weekly_used" "$weekly_reset_human"
}

print_usage_snapshot_header() {
  printf '%-10s %-16s %-16s %-16s %-12s %-8s %-12s %-8s %-12s %-s\n' \
    "KIND" "STATUS" "BRANCH" "ACCOUNT" "SOURCE" "5H%" "5H RESET" "WEEK%" "W RESET" "WORKSPACE"
}

print_usage_snapshot_row() {
  local kind="$1"
  local link_status="$2"
  local repo_root="$3"
  local branch="$4"
  local workspace="$5"
  local worktree_path="$6"
  local linked_account="$7"
  local default_profile="$8"
  local codex_home="$9"
  local auth_status="${10}"
  local status_source="${11}"
  local five_hour_used="${12}"
  local five_hour_reset_human="${13}"
  local weekly_used="${14}"
  local weekly_reset_human="${15}"
  local display_path
  display_path="$workspace"
  if [[ -z "$display_path" ]]; then
    display_path="$worktree_path"
  fi
  printf '%-10s %-16s %-16s %-16s %-12s %-8s %-12s %-8s %-12s %-s\n' \
    "$kind" "$link_status" "${branch:--}" "${linked_account:--}" "${status_source:--}" \
    "${five_hour_used:--}" "${five_hour_reset_human:--}" "${weekly_used:--}" "${weekly_reset_human:--}" "$display_path"
}

write_usage_snapshot_artifact() {
  local output_dir="$1"
  local workspace="$2"
  local generated_at="$3"
  local rows_file="$4"
  local json_path markdown_path first row

  mkdir -p "$output_dir"
  json_path="$(usage_snapshot_json_path "$output_dir")"
  markdown_path="$(usage_snapshot_markdown_path "$output_dir")"

  {
    printf '{\n'
    printf '  "schema_version": "%s",\n' "$(json_escape "$USAGE_SNAPSHOT_SCHEMA_VERSION")"
    printf '  "generated_at": "%s",\n' "$(json_escape "$generated_at")"
    printf '  "workspace": "%s",\n' "$(json_escape "$workspace")"
    printf '  "entries": [\n'
    first="true"
    while IFS= read -r row; do
      [[ -n "$row" ]] || continue
      IFS=$'\037' read -r kind link_status repo_root branch row_workspace worktree_path linked_account default_profile codex_home auth_status status_source five_hour_used five_hour_reset_human weekly_used weekly_reset_human <<<"$row"
      if [[ "$first" != "true" ]]; then
        printf ',\n'
      fi
      first="false"
      printf '    {\n'
      printf '      "kind": "%s",\n' "$(json_escape "$kind")"
      printf '      "link_status": "%s",\n' "$(json_escape "$link_status")"
      if [[ -n "$repo_root" ]]; then printf '      "repo": "%s",\n' "$(json_escape "$repo_root")"; else printf '      "repo": null,\n'; fi
      if [[ -n "$branch" ]]; then printf '      "branch": "%s",\n' "$(json_escape "$branch")"; else printf '      "branch": null,\n'; fi
      if [[ -n "$row_workspace" ]]; then printf '      "workspace": "%s",\n' "$(json_escape "$row_workspace")"; else printf '      "workspace": null,\n'; fi
      if [[ -n "$worktree_path" ]]; then printf '      "worktree": "%s",\n' "$(json_escape "$worktree_path")"; else printf '      "worktree": null,\n'; fi
      if [[ -n "$linked_account" ]]; then printf '      "linked_account": "%s",\n' "$(json_escape "$linked_account")"; else printf '      "linked_account": null,\n'; fi
      if [[ -n "$default_profile" ]]; then printf '      "default_profile": "%s",\n' "$(json_escape "$default_profile")"; else printf '      "default_profile": null,\n'; fi
      if [[ -n "$codex_home" ]]; then printf '      "codex_home": "%s",\n' "$(json_escape "$codex_home")"; else printf '      "codex_home": null,\n'; fi
      if [[ -n "$auth_status" ]]; then printf '      "auth_status": "%s",\n' "$(json_escape "$auth_status")"; else printf '      "auth_status": null,\n'; fi
      if [[ -n "$status_source" ]]; then printf '      "status_source": "%s",\n' "$(json_escape "$status_source")"; else printf '      "status_source": null,\n'; fi
      if [[ -n "$five_hour_used" ]]; then printf '      "five_hour_used_percent": %s,\n' "$five_hour_used"; else printf '      "five_hour_used_percent": null,\n'; fi
      if [[ -n "$five_hour_reset_human" ]]; then printf '      "five_hour_reset_after_human": "%s",\n' "$(json_escape "$five_hour_reset_human")"; else printf '      "five_hour_reset_after_human": null,\n'; fi
      if [[ -n "$weekly_used" ]]; then printf '      "weekly_used_percent": %s,\n' "$weekly_used"; else printf '      "weekly_used_percent": null,\n'; fi
      if [[ -n "$weekly_reset_human" ]]; then printf '      "weekly_reset_after_human": "%s"\n' "$(json_escape "$weekly_reset_human")"; else printf '      "weekly_reset_after_human": null\n'; fi
      printf '    }'
    done <"$rows_file"
    printf '\n  ]\n'
    printf '}\n'
  } >"$json_path"

  {
    printf '# Usage Snapshot\n\n'
    printf -- '- Generated at: `%s`\n' "$generated_at"
    printf -- '- Workspace: `%s`\n\n' "$workspace"
    printf '| Kind | Status | Branch | Account | Source | 5H%% | 5H Reset | Week%% | Week Reset | Workspace |\n'
    printf '|---|---|---|---|---|---|---|---|---|---|\n'
    while IFS= read -r row; do
      [[ -n "$row" ]] || continue
      IFS=$'\037' read -r kind link_status repo_root branch row_workspace worktree_path linked_account default_profile codex_home auth_status status_source five_hour_used five_hour_reset_human weekly_used weekly_reset_human <<<"$row"
      local display_path
      display_path="$row_workspace"
      if [[ -z "$display_path" ]]; then
        display_path="$worktree_path"
      fi
      printf '| %s | %s | %s | %s | %s | %s | %s | %s | %s | %s |\n' \
        "$kind" "${link_status:--}" "${branch:--}" "${linked_account:--}" "${status_source:--}" \
        "${five_hour_used:--}" "${five_hour_reset_human:--}" "${weekly_used:--}" "${weekly_reset_human:--}" "$display_path"
    done <"$rows_file"
  } >"$markdown_path"

  printf 'Wrote %s\n' "$json_path"
  printf 'Wrote %s\n' "$markdown_path"
}

cmd_usage_snapshot() {
  local workspace=""
  local all="false"
  local output_dir=""
  local generated_at rows_file

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --output-dir)
        output_dir="$2"
        shift 2
        ;;
      *)
        fail "unknown option for usage snapshot: $1"
        ;;
    esac
  done

  [[ "$all" == "true" ]] || fail "usage snapshot currently requires --all"
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  rows_file="$(mktemp)"
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if [[ -z "$output_dir" ]]; then
    output_dir="$(usage_artifact_dir "$workspace")"
  fi
  usage_snapshot_for_workspace "$workspace" >"$rows_file"

  print_usage_snapshot_header
  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    IFS=$'\037' read -r kind link_status repo_root branch row_workspace worktree_path linked_account default_profile codex_home auth_status status_source five_hour_used five_hour_reset_human weekly_used weekly_reset_human <<<"$row"
    print_usage_snapshot_row "$kind" "$link_status" "$repo_root" "$branch" "$row_workspace" "$worktree_path" "$linked_account" "$default_profile" "$codex_home" "$auth_status" "$status_source" "$five_hour_used" "$five_hour_reset_human" "$weekly_used" "$weekly_reset_human"
  done <"$rows_file"

  output_dir="$(abspath "$output_dir")"
  write_usage_snapshot_artifact "$output_dir" "$workspace" "$generated_at" "$rows_file"
  rm -f "$rows_file"
}

usage_map_for_repo() {
  local repo_root="$1"
  local row worktree_path git_branch metadata_file metadata_repo metadata_worktree metadata_branch linked_account default_profile
  local link_status codex_home status_source last_updated workspace_path
  local adapter

  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    worktree_path="${row%%$'\t'*}"
    git_branch="${row#*$'\t'}"
    metadata_file="$(worktree_meta_file "$worktree_path")"
    metadata_repo=""
    metadata_worktree=""
    metadata_branch=""
    linked_account=""
    default_profile=""
    codex_home=""
    status_source="unavailable"
    last_updated=""
    workspace_path=""
    link_status="unlinked"

    if [[ -d "$worktree_path/.codex-home" ]]; then
      workspace_path="$worktree_path"
      default_profile="$(read_default_profile "$worktree_path")"
      if [[ -n "$default_profile" && -d "$(profile_home "$worktree_path" "$default_profile")" ]]; then
        codex_home="$(profile_home "$worktree_path" "$default_profile")"
        status_source="$(status_source_for_profile "$worktree_path" "$default_profile")"
      fi
    fi

    if [[ -f "$metadata_file" ]]; then
      metadata_repo="$(worktree_metadata_field "$metadata_file" repo || true)"
      metadata_worktree="$(worktree_metadata_field "$metadata_file" worktree || true)"
      metadata_branch="$(worktree_metadata_field "$metadata_file" branch || true)"
      linked_account="$(worktree_metadata_field "$metadata_file" account || true)"
      last_updated="$(worktree_metadata_field "$metadata_file" created_at || true)"

      if [[ -z "$metadata_repo" || -z "$metadata_worktree" || -z "$metadata_branch" || -z "$linked_account" ]]; then
        link_status="metadata-invalid"
      elif [[ "$metadata_repo" != "$repo_root" ]]; then
        link_status="repo-mismatch"
      elif [[ "$metadata_worktree" != "$worktree_path" ]]; then
        link_status="path-mismatch"
      elif [[ "$metadata_branch" != "$git_branch" ]]; then
        link_status="branch-mismatch"
      elif [[ -n "$workspace_path" ]] && ! account_exists "$worktree_path" "$linked_account"; then
        link_status="account-missing"
      else
        link_status="linked"
      fi

      if [[ -n "$workspace_path" && -n "$linked_account" && -d "$(profile_home "$worktree_path" "$linked_account")" ]]; then
        codex_home="$(profile_home "$worktree_path" "$linked_account")"
      fi
    fi

    emit_usage_map_row "worktree" "$link_status" "$repo_root" "$git_branch" "$workspace_path" "$worktree_path" "$linked_account" "$default_profile" "$codex_home" "$status_source" "$last_updated"
  done < <(list_git_worktrees "$repo_root")
}

print_usage_map_header() {
  printf '%-10s %-16s %-16s %-16s %-16s %-12s %-s\n' \
    "KIND" "STATUS" "BRANCH" "ACCOUNT" "DEFAULT" "SOURCE" "WORKSPACE"
}

print_usage_map_row() {
  local kind="$1"
  local link_status="$2"
  local repo_root="$3"
  local branch="$4"
  local workspace="$5"
  local worktree_path="$6"
  local linked_account="$7"
  local default_profile="$8"
  local codex_home="$9"
  local status_source="${10}"
  local last_updated="${11}"
  local display_path
  display_path="$workspace"
  if [[ -z "$display_path" ]]; then
    display_path="$worktree_path"
  fi
  printf '%-10s %-16s %-16s %-16s %-16s %-12s %-s\n' \
    "$kind" "$link_status" "${branch:--}" "${linked_account:--}" "${default_profile:--}" "${status_source:--}" "$display_path"
}

write_usage_map_artifact() {
  local output_dir="$1"
  local mode="$2"
  local workspace="$3"
  local repo_root="$4"
  local generated_at="$5"
  local rows_file="$6"
  local json_path markdown_path first row

  mkdir -p "$output_dir"
  json_path="$(usage_map_json_path "$output_dir")"
  markdown_path="$(usage_map_markdown_path "$output_dir")"

  {
    printf '{\n'
    printf '  "schema_version": "%s",\n' "$(json_escape "$USAGE_MAP_SCHEMA_VERSION")"
    printf '  "generated_at": "%s",\n' "$(json_escape "$generated_at")"
    printf '  "mode": "%s",\n' "$(json_escape "$mode")"
    if [[ -n "$workspace" ]]; then
      printf '  "workspace": "%s",\n' "$(json_escape "$workspace")"
    else
      printf '  "workspace": null,\n'
    fi
    if [[ -n "$repo_root" ]]; then
      printf '  "repo": "%s",\n' "$(json_escape "$repo_root")"
    else
      printf '  "repo": null,\n'
    fi
    printf '  "entries": [\n'
    first="true"
    while IFS= read -r row; do
      [[ -n "$row" ]] || continue
      IFS=$'\037' read -r kind link_status row_repo branch row_workspace worktree_path linked_account default_profile codex_home status_source last_updated <<<"$row"
      if [[ "$first" != "true" ]]; then
        printf ',\n'
      fi
      first="false"
      printf '    {\n'
      printf '      "kind": "%s",\n' "$(json_escape "$kind")"
      printf '      "link_status": "%s",\n' "$(json_escape "$link_status")"
      if [[ -n "$row_repo" ]]; then printf '      "repo": "%s",\n' "$(json_escape "$row_repo")"; else printf '      "repo": null,\n'; fi
      if [[ -n "$branch" ]]; then printf '      "branch": "%s",\n' "$(json_escape "$branch")"; else printf '      "branch": null,\n'; fi
      if [[ -n "$row_workspace" ]]; then printf '      "workspace": "%s",\n' "$(json_escape "$row_workspace")"; else printf '      "workspace": null,\n'; fi
      if [[ -n "$worktree_path" ]]; then printf '      "worktree": "%s",\n' "$(json_escape "$worktree_path")"; else printf '      "worktree": null,\n'; fi
      if [[ -n "$linked_account" ]]; then printf '      "linked_account": "%s",\n' "$(json_escape "$linked_account")"; else printf '      "linked_account": null,\n'; fi
      if [[ -n "$default_profile" ]]; then printf '      "default_profile": "%s",\n' "$(json_escape "$default_profile")"; else printf '      "default_profile": null,\n'; fi
      if [[ -n "$codex_home" ]]; then printf '      "codex_home": "%s",\n' "$(json_escape "$codex_home")"; else printf '      "codex_home": null,\n'; fi
      if [[ -n "$status_source" ]]; then printf '      "status_source": "%s",\n' "$(json_escape "$status_source")"; else printf '      "status_source": null,\n'; fi
      if [[ -n "$last_updated" ]]; then printf '      "last_updated": "%s"\n' "$(json_escape "$last_updated")"; else printf '      "last_updated": null\n'; fi
      printf '    }'
    done <"$rows_file"
    printf '\n  ]\n'
    printf '}\n'
  } >"$json_path"

  {
    printf '# Usage Map\n\n'
    printf -- '- Generated at: `%s`\n' "$generated_at"
    printf -- '- Mode: `%s`\n' "$mode"
    if [[ -n "$workspace" ]]; then
      printf -- '- Workspace: `%s`\n' "$workspace"
    fi
    if [[ -n "$repo_root" ]]; then
      printf -- '- Repo: `%s`\n' "$repo_root"
    fi
    printf '\n| Kind | Status | Branch | Account | Default | Source | Workspace |\n'
    printf '|---|---|---|---|---|---|---|\n'
    while IFS= read -r row; do
      [[ -n "$row" ]] || continue
      IFS=$'\037' read -r kind link_status row_repo branch row_workspace worktree_path linked_account default_profile codex_home status_source last_updated <<<"$row"
      local display_path
      display_path="$row_workspace"
      if [[ -z "$display_path" ]]; then
        display_path="$worktree_path"
      fi
      printf '| %s | %s | %s | %s | %s | %s | %s |\n' \
        "$kind" "${link_status:--}" "${branch:--}" "${linked_account:--}" "${default_profile:--}" "${status_source:--}" "$display_path"
    done <"$rows_file"
  } >"$markdown_path"

  printf 'Wrote %s\n' "$json_path"
  printf 'Wrote %s\n' "$markdown_path"
}

cmd_usage_map() {
  local workspace=""
  local repo=""
  local all="false"
  local output_dir=""
  local generated_at rows_file repo_root mode

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --repo)
        repo="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --output-dir)
        output_dir="$2"
        shift 2
        ;;
      *)
        fail "unknown option for usage map: $1"
        ;;
    esac
  done

  if [[ "$all" == "true" && -n "$repo" ]]; then
    fail "usage map accepts either --all or --repo <repo>, not both"
  fi
  if [[ "$all" != "true" && -z "$repo" ]]; then
    fail "usage map requires --all or --repo <repo>"
  fi

  rows_file="$(mktemp)"
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mode="workspace"
  repo_root=""

  if [[ -n "$repo" ]]; then
    require_cmd git
    repo_root="$(git_repo_root "$repo")" || fail "repo is not a git repository: $repo"
    mode="repo"
    usage_map_for_repo "$repo_root" >"$rows_file"
  else
    workspace="$(resolve_workspace "$workspace")"
    usage_map_for_workspace "$workspace" >"$rows_file"
    if [[ -z "$output_dir" ]]; then
      output_dir="$(usage_artifact_dir "$workspace")"
    fi
  fi

  print_usage_map_header
  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    IFS=$'\037' read -r kind link_status row_repo branch row_workspace worktree_path linked_account default_profile codex_home status_source last_updated <<<"$row"
    print_usage_map_row "$kind" "$link_status" "$row_repo" "$branch" "$row_workspace" "$worktree_path" "$linked_account" "$default_profile" "$codex_home" "$status_source" "$last_updated"
  done <"$rows_file"

  if [[ -n "$output_dir" ]]; then
    output_dir="$(abspath "$output_dir")"
    write_usage_map_artifact "$output_dir" "$mode" "$workspace" "$repo_root" "$generated_at" "$rows_file"
  fi

  rm -f "$rows_file"
}

json_array_from_args() {
  local first="true"
  local arg
  printf '['
  for arg in "$@"; do
    if [[ "$first" == "true" ]]; then
      first="false"
    else
      printf ', '
    fi
    printf '"%s"' "$(json_escape "$arg")"
  done
  printf ']'
}

write_execution_artifact() {
  local artifact_dir="$1"
  local generated_at="$2"
  local workspace="$3"
  local account="$4"
  local home_dir="$5"
  local auth="$6"
  local preflight_ok="$7"
  local exit_code="$8"
  local codex_profile="$9"
  shift 9
  local command_args=("$@")

  mkdir -p "$artifact_dir"
  local stamp artifact_file latest_file
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  artifact_file="$artifact_dir/execution-${stamp}-${account}.json"
  latest_file="$artifact_dir/latest-execution.json"

  {
    printf '{\n'
    printf '  "schema_version": "%s",\n' "$(json_escape "$EXECUTION_ARTIFACT_SCHEMA_VERSION")"
    printf '  "generated_at": "%s",\n' "$(json_escape "$generated_at")"
    printf '  "workspace": "%s",\n' "$(json_escape "$workspace")"
    printf '  "account": "%s",\n' "$(json_escape "$account")"
    printf '  "codex_home": "%s",\n' "$(json_escape "$home_dir")"
    if [[ -n "$codex_profile" ]]; then
      printf '  "codex_profile": "%s",\n' "$(json_escape "$codex_profile")"
    else
      printf '  "codex_profile": null,\n'
    fi
    printf '  "auth_status": "%s",\n' "$(json_escape "$auth")"
    printf '  "preflight_ok": %s,\n' "$preflight_ok"
    printf '  "exit_code": %s,\n' "$exit_code"
    printf '  "command": '
    json_array_from_args "${command_args[@]}"
    printf '\n'
    printf '}\n'
  } >"$artifact_file"

  cp "$artifact_file" "$latest_file"
  printf '%s\n' "$artifact_file"
}

cmd_report_status() {
  local profile=""
  local workspace=""
  local all="false"
  local requested_adapter="auto"
  local output_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --adapter)
        requested_adapter="$2"
        shift 2
        ;;
      --output-dir)
        output_dir="$2"
        shift 2
        ;;
      *)
        if [[ -z "$profile" ]]; then
          profile="$1"
          shift
        else
          fail "unknown option for report status: $1"
        fi
        ;;
    esac
  done

  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local adapter
  adapter="$(resolve_status_adapter "$requested_adapter" "$workspace")"
  if [[ -z "$output_dir" ]]; then
    output_dir="$workspace/.codex-home/artifacts/status"
  fi
  output_dir="$(abspath "$output_dir")"
  local raw_dir
  raw_dir="$output_dir/raw"
  mkdir -p "$raw_dir"

  local generated_at
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  local report_json
  report_json="$output_dir/status-report.json"
  local report_md
  report_md="$output_dir/status-report.md"

  {
    printf '{\n'
    printf '  "schema_version": "%s",\n' "$(json_escape "$STATUS_REPORT_SCHEMA_VERSION")"
    printf '  "generated_at": "%s",\n' "$(json_escape "$generated_at")"
    printf '  "workspace": "%s",\n' "$(json_escape "$workspace")"
    printf '  "adapter_requested": "%s",\n' "$(json_escape "$requested_adapter")"
    printf '  "adapter_used": "%s",\n' "$(json_escape "$adapter")"
    printf '  "profiles": [\n'

    local first="true"
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      set_profile_env "$workspace" "$candidate"

      local auth source fuelcheck_status="not_run" fuelcheck_raw="" login_status_file
      local codex_file="" claude_file="" gemini_file=""
      local codex_root="" claude_root="" gemini_root=""
      local plan_type="" credits_balance="" credits_unlimited="" primary_used="" primary_reset="" weekly_used="" weekly_reset=""
      local primary_reset_at="" weekly_reset_at="" primary_reset_human="" weekly_reset_human=""
      local claude_plan="" claude_source="" claude_five_used="" claude_five_reset_at="" claude_five_reset_seconds="" claude_five_reset_human=""
      local claude_week_used="" claude_week_reset_at="" claude_week_reset_seconds="" claude_week_reset_human=""
      local gemini_tier="" gemini_token_refreshed="" gemini_flash_used="" gemini_flash_reset_at="" gemini_flash_reset_seconds="" gemini_flash_reset_human=""
      local gemini_pro_used="" gemini_pro_reset_at="" gemini_pro_reset_seconds="" gemini_pro_reset_human=""
      local snapshot
      snapshot="$(status_snapshot "$workspace" "$candidate" "$adapter")"
      auth="${snapshot%%$'\t'*}"
      source="${snapshot#*$'\t'}"

      login_status_file="$raw_dir/${candidate}-login-status.txt"
      write_text_file "$login_status_file" "$auth"

      codex_root="$(resolve_provider_root "$workspace" codex "$(profile_home "$workspace" "$candidate")")"
      claude_root="$(resolve_provider_root "$workspace" claude "$(profile_home "$workspace" "$candidate")")"
      gemini_root="$(resolve_provider_root "$workspace" gemini "$(profile_home "$workspace" "$candidate")")"

      if [[ "$adapter" == "fuelcheck" ]]; then
        if fuelcheck_raw="$(collect_fuelcheck_json codex "$codex_root" "$workspace")"; then
          fuelcheck_status="ok"
          codex_file="$raw_dir/${candidate}-fuelcheck-codex.json"
          write_text_file "$codex_file" "$fuelcheck_raw"
          plan_type="$(fuelcheck_field "$codex_file" '.Codex?.plan_type // .[0].usage.identity.loginMethod // .[0].usage.loginMethod')"
          credits_balance="$(fuelcheck_field "$codex_file" '.Codex?.credits.balance // (.[0].credits.remaining | tostring)')"
          credits_unlimited="$(fuelcheck_field "$codex_file" '.Codex?.credits.unlimited')"
          primary_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.used_percent // .[0].usage.primary.usedPercent')"
          primary_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.reset_after_seconds')"
          primary_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.primary.resetsAt')"
          weekly_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.used_percent // .[0].usage.secondary.usedPercent')"
          weekly_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.reset_after_seconds')"
          weekly_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.secondary.resetsAt')"
          if [[ -z "$primary_reset" && -n "$primary_reset_at" ]]; then
            primary_reset="$(seconds_until_iso "$primary_reset_at")"
          fi
          if [[ -z "$weekly_reset" && -n "$weekly_reset_at" ]]; then
            weekly_reset="$(seconds_until_iso "$weekly_reset_at")"
          fi
          primary_reset_human="$(format_duration "$primary_reset")"
          weekly_reset_human="$(format_duration "$weekly_reset")"
        else
          fuelcheck_status="unavailable"
        fi
        if fuelcheck_raw="$(collect_fuelcheck_json claude "$claude_root" "$workspace")"; then
          claude_file="$raw_dir/${candidate}-fuelcheck-claude.json"
          write_text_file "$claude_file" "$fuelcheck_raw"
          claude_plan="$(fuelcheck_field "$claude_file" '.Claude.account.subscriptionType')"
          claude_source="$(fuelcheck_field "$claude_file" '.Claude.source')"
          claude_five_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.five_hour.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_five_reset_at="$(fuelcheck_field "$claude_file" '.Claude.usage.five_hour.resets_at')"
          claude_five_reset_seconds="$(seconds_until_iso "$claude_five_reset_at")"
          claude_five_reset_human="$(format_duration "$claude_five_reset_seconds")"
          claude_week_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.seven_day.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_week_reset_at="$(fuelcheck_field "$claude_file" '.Claude.usage.seven_day.resets_at')"
          claude_week_reset_seconds="$(seconds_until_iso "$claude_week_reset_at")"
          claude_week_reset_human="$(format_duration "$claude_week_reset_seconds")"
        fi
        if fuelcheck_raw="$(collect_fuelcheck_json gemini "$gemini_root" "$workspace")"; then
          gemini_file="$raw_dir/${candidate}-fuelcheck-gemini.json"
          write_text_file "$gemini_file" "$fuelcheck_raw"
          gemini_tier="$(fuelcheck_field "$gemini_file" '.Gemini.tier')"
          gemini_token_refreshed="$(fuelcheck_field "$gemini_file" '.Gemini.token_refreshed')"
          gemini_flash_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_flash_reset_at="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].resetTime)')"
          gemini_flash_reset_seconds="$(seconds_until_iso "$gemini_flash_reset_at")"
          gemini_flash_reset_human="$(format_duration "$gemini_flash_reset_seconds")"
          gemini_pro_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-pro" or .modelId=="gemini-3-pro-preview")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_pro_reset_at="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-pro" or .modelId=="gemini-3-pro-preview")][0].resetTime)')"
          gemini_pro_reset_seconds="$(seconds_until_iso "$gemini_pro_reset_at")"
          gemini_pro_reset_human="$(format_duration "$gemini_pro_reset_seconds")"
        fi
      fi

      if [[ "$first" != "true" ]]; then
        printf ',\n'
      fi
      first="false"

      printf '    {\n'
      printf '      "name": "%s",\n' "$(json_escape "$candidate")"
      printf '      "default": %s,\n' "$([[ "$candidate" == "$default_profile" ]] && printf 'true' || printf 'false')"
      printf '      "home": "%s",\n' "$(json_escape "$(profile_home "$workspace" "$candidate")")"
      printf '      "auth_status": "%s",\n' "$(json_escape "$auth")"
      printf '      "status_source": "%s",\n' "$(json_escape "$source")"
      printf '      "fuelcheck_status": "%s",\n' "$(json_escape "$fuelcheck_status")"
      if [[ -n "$plan_type" ]]; then
        printf '      "plan_type": "%s",\n' "$(json_escape "$plan_type")"
      else
        printf '      "plan_type": null,\n'
      fi
      if [[ -n "$credits_balance" ]]; then
        printf '      "credits_balance": "%s",\n' "$(json_escape "$credits_balance")"
      else
        printf '      "credits_balance": null,\n'
      fi
      if [[ -n "$credits_unlimited" ]]; then
        printf '      "credits_unlimited": %s,\n' "$credits_unlimited"
      else
        printf '      "credits_unlimited": null,\n'
      fi
      if [[ -n "$primary_used" ]]; then
        printf '      "five_hour_used_percent": %s,\n' "$primary_used"
      else
        printf '      "five_hour_used_percent": null,\n'
      fi
      if [[ -n "$primary_reset" ]]; then
        printf '      "five_hour_reset_after_seconds": %s,\n' "$primary_reset"
      else
        printf '      "five_hour_reset_after_seconds": null,\n'
      fi
      if [[ -n "$primary_reset_human" ]]; then
        printf '      "five_hour_reset_after_human": "%s",\n' "$(json_escape "$primary_reset_human")"
      else
        printf '      "five_hour_reset_after_human": null,\n'
      fi
      if [[ -n "$weekly_used" ]]; then
        printf '      "weekly_used_percent": %s,\n' "$weekly_used"
      else
        printf '      "weekly_used_percent": null,\n'
      fi
      if [[ -n "$weekly_reset" ]]; then
        printf '      "weekly_reset_after_seconds": %s,\n' "$weekly_reset"
      else
        printf '      "weekly_reset_after_seconds": null,\n'
      fi
      if [[ -n "$weekly_reset_human" ]]; then
        printf '      "weekly_reset_after_human": "%s",\n' "$(json_escape "$weekly_reset_human")"
      else
        printf '      "weekly_reset_after_human": null,\n'
      fi
      printf '      "providers": {\n'
      printf '        "codex": {\n'
      print_json_string_or_null "status" "$fuelcheck_status"
      print_json_string_or_null "plan_type" "$plan_type"
      print_json_string_or_null "credits_balance" "$credits_balance"
      print_json_bool_or_null "credits_unlimited" "$credits_unlimited"
      print_json_number_or_null "five_hour_used_percent" "$primary_used"
      print_json_number_or_null "five_hour_reset_after_seconds" "$primary_reset"
      print_json_string_or_null "five_hour_reset_after_human" "$primary_reset_human"
      print_json_number_or_null "weekly_used_percent" "$weekly_used"
      print_json_number_or_null "weekly_reset_after_seconds" "$weekly_reset"
      if [[ -n "$weekly_reset_human" ]]; then
        printf '        "weekly_reset_after_human": "%s"\n' "$(json_escape "$weekly_reset_human")"
      else
        printf '        "weekly_reset_after_human": null\n'
      fi
      printf '        },\n'
      printf '        "claude": {\n'
      if [[ -n "$claude_plan$claude_source$claude_five_used$claude_week_used" ]]; then
        print_json_string_or_null "status" "ok"
      else
        print_json_string_or_null "status" "unavailable"
      fi
      print_json_string_or_null "plan" "$claude_plan"
      print_json_string_or_null "source" "$claude_source"
      print_json_number_or_null "five_hour_used_percent" "$claude_five_used"
      print_json_string_or_null "five_hour_reset_at" "$claude_five_reset_at"
      print_json_number_or_null "five_hour_reset_after_seconds" "$claude_five_reset_seconds"
      print_json_string_or_null "five_hour_reset_after_human" "$claude_five_reset_human"
      print_json_number_or_null "weekly_used_percent" "$claude_week_used"
      print_json_string_or_null "weekly_reset_at" "$claude_week_reset_at"
      print_json_number_or_null "weekly_reset_after_seconds" "$claude_week_reset_seconds"
      if [[ -n "$claude_week_reset_human" ]]; then
        printf '        "weekly_reset_after_human": "%s"\n' "$(json_escape "$claude_week_reset_human")"
      else
        printf '        "weekly_reset_after_human": null\n'
      fi
      printf '        },\n'
      printf '        "gemini": {\n'
      if [[ -n "$gemini_tier$gemini_flash_used$gemini_pro_used$gemini_token_refreshed" ]]; then
        print_json_string_or_null "status" "ok"
      else
        print_json_string_or_null "status" "unavailable"
      fi
      print_json_string_or_null "tier" "$gemini_tier"
      print_json_bool_or_null "token_refreshed" "$gemini_token_refreshed"
      print_json_number_or_null "flash_used_percent" "$gemini_flash_used"
      print_json_string_or_null "flash_reset_at" "$gemini_flash_reset_at"
      print_json_number_or_null "flash_reset_after_seconds" "$gemini_flash_reset_seconds"
      print_json_string_or_null "flash_reset_after_human" "$gemini_flash_reset_human"
      print_json_number_or_null "pro_used_percent" "$gemini_pro_used"
      print_json_string_or_null "pro_reset_at" "$gemini_pro_reset_at"
      print_json_number_or_null "pro_reset_after_seconds" "$gemini_pro_reset_seconds"
      if [[ -n "$gemini_pro_reset_human" ]]; then
        printf '        "pro_reset_after_human": "%s"\n' "$(json_escape "$gemini_pro_reset_human")"
      else
        printf '        "pro_reset_after_human": null\n'
      fi
      printf '        }\n'
      printf '      },\n'
      printf '      "raw_files": {\n'
      printf '        "login_status": "%s",\n' "$(json_escape "$login_status_file")"
      if [[ -n "$codex_file" ]]; then printf '        "fuelcheck_codex_json": "%s",\n' "$(json_escape "$codex_file")"; else printf '        "fuelcheck_codex_json": null,\n'; fi
      if [[ -n "$claude_file" ]]; then printf '        "fuelcheck_claude_json": "%s",\n' "$(json_escape "$claude_file")"; else printf '        "fuelcheck_claude_json": null,\n'; fi
      if [[ -n "$gemini_file" ]]; then printf '        "fuelcheck_gemini_json": "%s"\n' "$(json_escape "$gemini_file")"; else printf '        "fuelcheck_gemini_json": null\n'; fi
      printf '      }\n'
      printf '    }'
    done < <(iterate_target_profiles "$workspace" "$profile" "$all")

    printf '\n  ]\n'
    printf '}\n'
  } >"$report_json"

  {
    printf '# Status Report\n\n'
    printf -- '- Generated at: `%s`\n' "$generated_at"
    printf -- '- Workspace: `%s`\n' "$workspace"
    printf -- '- Adapter requested: `%s`\n' "$requested_adapter"
    printf -- '- Adapter used: `%s`\n\n' "$adapter"
    printf '| Profile | Codex | Claude | Gemini | Default | Fuelcheck |\n'
    printf '|---|---|---|---|---|---|\n'
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      local snapshot auth source fuelcheck_status codex_file claude_file gemini_file plan_type primary_used primary_reset weekly_used weekly_reset primary_reset_at weekly_reset_at primary_reset_human weekly_reset_human
      local claude_plan claude_five_used claude_five_reset_human gemini_tier gemini_flash_used gemini_flash_reset_human
      snapshot="$(status_snapshot "$workspace" "$candidate" "$adapter")"
      auth="${snapshot%%$'\t'*}"
      source="${snapshot#*$'\t'}"
      fuelcheck_status="n/a"
      plan_type="n/a"
      primary_used="n/a"
      primary_reset="n/a"
      weekly_used="n/a"
      weekly_reset="n/a"
      primary_reset_human="n/a"
      weekly_reset_human="n/a"
      claude_plan="n/a"
      claude_five_used="n/a"
      claude_five_reset_human="n/a"
      gemini_tier="n/a"
      gemini_flash_used="n/a"
      gemini_flash_reset_human="n/a"
      if [[ "$adapter" == "fuelcheck" ]]; then
        codex_file="$raw_dir/${candidate}-fuelcheck-codex.json"
        claude_file="$raw_dir/${candidate}-fuelcheck-claude.json"
        gemini_file="$raw_dir/${candidate}-fuelcheck-gemini.json"
        if [[ -f "$codex_file" ]]; then
          fuelcheck_status="ok"
          plan_type="$(fuelcheck_field "$codex_file" '.Codex?.plan_type // .[0].usage.identity.loginMethod // .[0].usage.loginMethod')"
          primary_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.used_percent // .[0].usage.primary.usedPercent')"
          primary_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.primary_window.reset_after_seconds')"
          primary_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.primary.resetsAt')"
          weekly_used="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.used_percent // .[0].usage.secondary.usedPercent')"
          weekly_reset="$(fuelcheck_field "$codex_file" '.Codex?.rate_limit.secondary_window.reset_after_seconds')"
          weekly_reset_at="$(fuelcheck_field "$codex_file" '.[0].usage.secondary.resetsAt')"
          if [[ -z "$primary_reset" && -n "$primary_reset_at" ]]; then
            primary_reset="$(seconds_until_iso "$primary_reset_at")"
          fi
          if [[ -z "$weekly_reset" && -n "$weekly_reset_at" ]]; then
            weekly_reset="$(seconds_until_iso "$weekly_reset_at")"
          fi
          primary_reset_human="$(format_duration "$primary_reset")"
          weekly_reset_human="$(format_duration "$weekly_reset")"
          [[ -n "$plan_type" ]] || plan_type="n/a"
          [[ -n "$primary_used" ]] || primary_used="n/a"
          [[ -n "$primary_reset_human" ]] || primary_reset_human="n/a"
        fi
        if [[ -f "$claude_file" ]]; then
          claude_plan="$(fuelcheck_field "$claude_file" '.Claude.account.subscriptionType')"
          claude_five_used="$(fuelcheck_field "$claude_file" '(.Claude.usage.five_hour.utilization | if . <= 1 then . * 100 else . end | round)')"
          claude_five_reset_human="$(format_duration "$(seconds_until_iso "$(fuelcheck_field "$claude_file" '.Claude.usage.five_hour.resets_at')")")"
          [[ -n "$claude_plan" ]] || claude_plan="n/a"
          [[ -n "$claude_five_used" ]] || claude_five_used="n/a"
          [[ -n "$claude_five_reset_human" ]] || claude_five_reset_human="n/a"
        fi
        if [[ -f "$gemini_file" ]]; then
          gemini_tier="$(fuelcheck_field "$gemini_file" '.Gemini.tier')"
          gemini_flash_used="$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].remainingFraction | (1 - .) * 100 | round)')"
          gemini_flash_reset_human="$(format_duration "$(seconds_until_iso "$(fuelcheck_field "$gemini_file" '([.Gemini.buckets[]? | select(.modelId=="gemini-2.5-flash" or .modelId=="gemini-2.5-flash-lite" or .modelId=="gemini-2.0-flash")][0].resetTime)')")")"
          [[ -n "$gemini_tier" ]] || gemini_tier="n/a"
          [[ -n "$gemini_flash_used" ]] || gemini_flash_used="n/a"
          [[ -n "$gemini_flash_reset_human" ]] || gemini_flash_reset_human="n/a"
        fi
        if [[ ! -f "$codex_file" && ! -f "$claude_file" && ! -f "$gemini_file" ]]; then
          fuelcheck_status="unavailable"
        else
          fuelcheck_status="ok"
        fi
      fi
      printf '| %s | %s | %s | %s | %s | %s |\n' \
        "$candidate" \
        "$(printf 'plan=%s 5h=%s reset=%s' "$plan_type" "$primary_used" "$primary_reset_human")" \
        "$(printf 'plan=%s 5h=%s reset=%s' "$claude_plan" "$claude_five_used" "$claude_five_reset_human")" \
        "$(printf 'tier=%s flash=%s reset=%s' "$gemini_tier" "$gemini_flash_used" "$gemini_flash_reset_human")" \
        "$([[ "$candidate" == "$default_profile" ]] && printf 'yes' || printf 'no')" \
        "$fuelcheck_status"
    done < <(iterate_target_profiles "$workspace" "$profile" "$all")
  } >"$report_md"

  printf 'Wrote %s\n' "$report_json"
  printf 'Wrote %s\n' "$report_md"
}

cmd_status() {
  local profile=""
  local workspace=""
  local all="false"
  local requested_adapter="auto"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --all)
        all="true"
        shift
        ;;
      --adapter)
        requested_adapter="$2"
        shift 2
        ;;
      *)
        if [[ -z "$profile" ]]; then
          profile="$1"
          shift
        else
          fail "unknown option for status: $1"
        fi
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"
  local adapter
  adapter="$(resolve_status_adapter "$requested_adapter" "$workspace")"

  local default_profile
  default_profile="$(read_default_profile "$workspace")"
  print_status_table_header
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    status_for_profile "$workspace" "$candidate" "$default_profile" "$adapter"
  done < <(iterate_target_profiles "$workspace" "$profile" "$all")
}

cmd_doctor() {
  local workspace=""
  local account=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --account)
        account="$2"
        shift 2
        ;;
      *)
        fail "unknown option for doctor: $1"
        ;;
    esac
  done
  workspace="$(resolve_workspace "$workspace")"
  ensure_workspace_layout "$workspace"

  printf 'Workspace: %s\n' "$workspace"
  if command -v codex >/dev/null 2>&1; then
    printf 'codex: %s\n' "$(command -v codex)"
  else
    printf 'codex: missing\n'
  fi
  if command -v jq >/dev/null 2>&1; then
    printf 'jq: %s\n' "$(command -v jq)"
  else
    printf 'jq: missing (optional)\n'
  fi
  if find_fuelcheck_bin "$workspace" >/dev/null 2>&1; then
    printf 'fuelcheck: %s\n' "$(find_fuelcheck_bin "$workspace")"
  else
    printf 'fuelcheck: missing (managed dependency not installed; rerun init without --skip-fuelcheck or install it manually)\n'
  fi
  printf 'provider roots:\n'
  cmd_provider_root_list --workspace "$workspace" || true
  printf 'profiles:\n'
  cmd_profile_list --workspace "$workspace" || true

  if [[ -n "$account" ]]; then
    local preflight resolved_account home_dir auth ok
    preflight="$(run_account_preflight "$workspace" "$account" "true")"
    resolved_account="${preflight%%$'\t'*}"
    preflight="${preflight#*$'\t'}"
    home_dir="${preflight%%$'\t'*}"
    preflight="${preflight#*$'\t'}"
    auth="${preflight%%$'\t'*}"
    ok="${preflight##*$'\t'}"

    printf 'account preflight:\n'
    printf 'account: %s\n' "$resolved_account"
    printf 'codex home: %s\n' "$home_dir"
    printf 'auth: %s\n' "$auth"
    if [[ "$ok" == "true" ]]; then
      printf 'preflight: ok\n'
    else
      printf 'preflight: failed\n'
      if ! command -v codex >/dev/null 2>&1; then
        printf 'reason: Codex CLI not installed\n'
      elif [[ ! -d "$home_dir" || ! -d "$home_dir/.codex" ]]; then
        printf 'reason: Codex home missing for selected account\n'
      elif ! auth_status_ok "$auth"; then
        printf 'reason: no active login for selected account\n'
      fi
      return 1
    fi
  fi
}

main() {
  local command="${1:-}"
  [[ -n "$command" ]] || {
    usage
    exit 1
  }
  shift || true

  case "$command" in
    init)
      cmd_init "$@"
      ;;
    worktree)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        create) cmd_worktree_create "$@" ;;
        list) cmd_worktree_list "$@" ;;
        doctor) cmd_worktree_doctor "$@" ;;
        *) fail "unknown worktree subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    usage)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        map) cmd_usage_map "$@" ;;
        snapshot) cmd_usage_snapshot "$@" ;;
        *) fail "unknown usage subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    profile)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        add) cmd_profile_add "$@" ;;
        list) cmd_profile_list "$@" ;;
        *) fail "unknown profile subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    provider-root)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        set) cmd_provider_root_set "$@" ;;
        list) cmd_provider_root_list "$@" ;;
        *) fail "unknown provider-root subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    use)
      cmd_use "$@"
      ;;
    login)
      cmd_login "$@"
      ;;
    run)
      cmd_run "$@"
      ;;
    codex)
      cmd_codex "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    report)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        status) cmd_report_status "$@" ;;
        *) fail "unknown report subcommand: ${sub:-<empty>}" ;;
      esac
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
